/* =====================================================================
   STAYFOLIO 서브페이지 공통 스타일 (sub.css)
   - style.css 의 헤더/푸터/타이포를 그대로 사용하고, 서브페이지 전용
     컴포넌트(배너/리스트/상세/폼/검색/로그인/문의)를 여기에 정의
   ===================================================================== */

/* 서브페이지는 헤더가 항상 어두운 바탕을 갖도록(흰 글자 가독성) */
.sub #header { background: rgba(20, 20, 20, 0.9); backdrop-filter: blur(10px); padding: 16px 0; }
.sub #header.scrolled { background: rgba(20, 20, 20, 0.92); }
.header-util .util-btn { display: flex; align-items: center; color: #fff; }

/* ---------- 페이지 상단 배너 ---------- */
.page-banner {
  position: relative;
  height: 420px;
  display: flex;
  align-items: center;
  color: #fff;
  overflow: hidden;
}
.page-banner img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.page-banner::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.55), rgba(0, 0, 0, 0.25));
}
.page-banner .inner { position: relative; z-index: 1; width: 100%; }
.page-banner .eyebrow span { background: rgba(255, 255, 255, 0.7); }
.page-banner .eyebrow { color: rgba(255, 255, 255, 0.85); }
.banner-title {
  margin-top: 14px;
  font-size: 46px;
  font-weight: 400;
  letter-spacing: -0.01em;
}
.banner-sub {
  margin-top: 16px;
  font-size: 17px;
  font-weight: 200;
  color: rgba(255, 255, 255, 0.82);
  line-height: 1.7;
}

/* ---------- 빵부스러기 ---------- */
.breadcrumb {
  margin-top: 8px;
  margin-bottom: 36px;
  font-size: 13px;
  color: #9a938c;
  letter-spacing: 0.04em;
}
.breadcrumb a { color: #9a938c; transition: color 0.3s; }
.breadcrumb a:hover { color: #8a6f55; }
.breadcrumb span { margin: 0 8px; color: #c9c0b8; }

/* ---------- 공통 섹션 래퍼 ---------- */
.sub-section { padding: 90px 0; }
.preorder-section,
.sub-section.no-banner { padding-top: 150px; } /* 탑 배너 없이 헤더 아래로 바로 시작 */
.sub-section.tint { background: #f7f3ef; }
.sub-section.beige { background: #e5dcd6; }
.section-head { margin-bottom: 40px; }
.section-head .sec-title { font-size: 30px; }

/* ---------- 필터 바 ---------- */
/* 스테이 목록 검색창 */
.stay-search {
  display: flex;
  align-items: center;
  gap: 12px;
  max-width: 520px;
  margin: 0 0 22px;
  padding: 14px 22px;
  border: 1px solid #e0dbd5;
  border-radius: 50px;
  background: #fff;
  transition: border-color 0.25s, box-shadow 0.25s;
}
.stay-search:focus-within {
  border-color: #8a6f55;
  box-shadow: 0 6px 20px rgba(120, 100, 85, 0.1);
}
.stay-search .ico { width: 20px; height: 20px; color: #8a6f55; flex: none; }
.stay-search input {
  flex: 1;
  border: none;
  background: none;
  font-size: 15px;
  color: #333;
}
.stay-search input::placeholder { color: #b3aca5; }
.stay-search input:focus { outline: none; }

.filter-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-bottom: 44px;
}
.filter-bar button {
  padding: 11px 26px;
  border: 1px solid #ddd;
  border-radius: 50px;
  font-size: 15px;
  color: #555;
  background: #fff;
  cursor: pointer;
  transition: all 0.25s;
}
.filter-bar button:hover { border-color: #8a6f55; color: #8a6f55; }
.filter-bar button.active { background: #2c2723; border-color: #2c2723; color: #fff; }

/* ---------- 스테이 카드 그리드 ---------- */
.stay-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 30px;
}
.stay-grid .stay-card {
  flex: none;
  width: 100%;
  min-width: 0;
  height: 420px;
}
.result-count { margin-bottom: 26px; font-size: 15px; color: #777; }
/* 검색 결과 0건 폴백 */
.no-result { display: none; padding: 30px 0 10px; text-align: center; }
.no-result.show { display: block; }
.nr-title { font-size: 22px; font-weight: 600; color: #2c2723; }
.nr-sub { margin-top: 10px; font-size: 14px; color: #8b837a; }
.nr-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30px;
  max-width: 880px;
  margin: 36px auto 0;
  text-align: left;
}
@media (max-width: 680px) {
  .nr-grid { grid-template-columns: 1fr; }
}
/* 클릭 유도 4분할 카드: 라운드 박스 4개 + 갭 */
.promo-quad {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 1fr 1fr;
  gap: 12px;
  height: 420px;
}
.pq-tile {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: flex-end;
  gap: 5px;
  padding: 20px 22px;
  background: #fff;
  border: 1px solid #ece5da;
  border-radius: 16px;
  box-shadow: 0 8px 20px rgba(70, 52, 35, 0.07);
  text-align: left;
  cursor: pointer;
  transition: transform 0.25s, box-shadow 0.25s;
}
button.pq-tile:hover { transform: translateY(-3px); box-shadow: 0 14px 28px rgba(70, 52, 35, 0.13); }
.pq-tile.pq-head { border: none; }
.pq-tile em {
  margin-top: auto;
  font-style: normal;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.2em;
  color: #c9a87c;
}
.pq-tile strong {
  font-size: 18px;
  font-weight: 600;
  line-height: 1.35;
  color: #2c2723;
}
/* 아이콘 서클 */
.pq-ic {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  transition: transform 0.25s;
}
.pq-ic .material-symbols-outlined { font-size: 22px; }
button.pq-tile:hover .pq-ic { transform: scale(1.08); }
.pq-ic.c1 { background: #f1e7d7; color: #8a6f55; }
.pq-ic.c2 { background: #e7eef6; color: #5b7a9d; }
.pq-ic.c3 { background: #e3efe6; color: #3e7d5a; }
.pq-ic.c4 { background: #f7e9e3; color: #c1654b; }
/* 한 줄 스토리 */
.pq-tile .pq-story {
  font-size: 11.5px;
  line-height: 1.5;
  color: #8b837a;
}
.pq-tile.pq-head .pq-story { color: rgba(250, 247, 243, 0.62); margin-top: 4px; }
button.pq-tile::after {
  content: "\2192";
  font-size: 14px;
  color: #8a6f55;
  opacity: 0;
  transform: translateX(-4px);
  transition: opacity 0.25s, transform 0.25s;
}
button.pq-tile:hover { background: #f7f3ef; }
button.pq-tile:hover::after { opacity: 1; transform: none; }
button.pq-tile.on { background: #f1e7d7; }
.pq-tile.pq-head {
  background: #211c18;
  cursor: default;
}
.pq-tile.pq-head strong { color: #faf7f3; font-size: 19px; }
.pq-tile.pq-head.alt { background: #8a6f55; }
.pq-tile.pq-head.alt em { color: #f3e1c3; }
.result-count strong { color: #2c2723; font-weight: 600; }

/* ---------- 페이지네이션 ---------- */
.pagination {
  display: flex;
  justify-content: center;
  gap: 10px;
  margin-top: 64px;
}
.pagination a {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 15px;
  color: #555;
  transition: all 0.25s;
}
.pagination a:hover { background: #efe9e3; color: #8a6f55; }
.pagination a.active { background: #2c2723; color: #fff; }

/* ---------- 저널(매거진) 리스트 ---------- */
body.sub:has(.journal-feature) .sub-section > .inner {
  padding-left: 0;
  padding-right: 0;
}
body.sub:has(.journal-feature) .sub-section > .inner > .breadcrumb {
  padding-left: 60px;
}
/* 매거진 위계: 큰 하이라이트 2개(첫 줄) + 표준 카드 4개 */
.journal-grid {
  display: grid;
  grid-template-columns: repeat(12, 1fr);
  gap: 56px 30px;
}
.journal-card { grid-column: span 3; cursor: pointer; }      /* 표준: 4-up */
.journal-card:nth-child(1),
.journal-card:nth-child(2) { grid-column: span 6; }          /* 하이라이트: 2-up */
.journal-card .thumb {
  position: relative;
  height: 230px;
  border-radius: 16px;
  overflow: hidden;
}
.journal-card:nth-child(1) .thumb,
.journal-card:nth-child(2) .thumb { height: 360px; border-radius: 20px; }
.journal-card .thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.7s ease;
}
.journal-card:hover .thumb img { transform: scale(1.06); }
.journal-card .cat {
  display: inline-block;
  margin-top: 20px;
  font-size: 12px;
  letter-spacing: 0.16em;
  color: #8a6f55;
  font-weight: 600;
}
.journal-card h3 {
  margin-top: 12px;
  font-size: 19px;
  font-weight: 500;
  color: #2c2723;
  line-height: 1.5;
  transition: color 0.2s;
}
.journal-card:nth-child(1) h3,
.journal-card:nth-child(2) h3 { margin-top: 14px; font-size: 25px; font-weight: 600; }
.journal-card:hover h3 { color: #8a6f55; }
.journal-card p {
  margin-top: 10px;
  font-size: 14px;
  color: #777;
  line-height: 1.65;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.journal-card:nth-child(1) p,
.journal-card:nth-child(2) p { font-size: 15px; -webkit-line-clamp: 3; max-width: 90%; }
/* 이달의 추천 - 에디터 쇼케이스 */
.best-band {
  width: 100vw;
  margin-left: calc(50% - 50vw);
  padding: 78px max(60px, calc(50vw - 700px)) 90px;
  background: #f7f3ef;
  margin-bottom: 90px;
}
.monthly-showcase {
  display: grid;
  grid-template-columns: minmax(520px, 710px) minmax(0, 640px);
  gap: 50px;
  align-items: start;
  max-width: 1400px;
  margin: 0 auto;
}
.monthly-main {
  position: relative;
  min-height: 410px;
  padding: 64px 58px;
  border-radius: 18px;
  background: #8a6f55;
  overflow: visible;
  color: #fff;
  box-shadow: 0 20px 44px rgba(94, 72, 52, 0.12);
  transition: transform 0.3s, box-shadow 0.3s;
}
.monthly-main::after {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 18px;
  background: url("../images/cloud.png") center bottom / cover no-repeat;
  opacity: 0.72;
  pointer-events: none;
}
.monthly-showcase:hover .monthly-main {
  transform: translateY(-4px);
  box-shadow: 0 26px 54px rgba(94, 72, 52, 0.16);
}
.monthly-copy {
  position: absolute;
  left: 58px;
  top: 50%;
  z-index: 2;
  transform: translateY(-50%);
  max-width: 420px;
}
.monthly-copy .band-eyebrow {
  margin-bottom: 28px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.26em;
  color: rgba(255, 255, 255, 0.72);
}
.monthly-copy .sec-title {
  font-size: clamp(34px, 3vw, 46px);
  font-weight: 300;
  line-height: 1.2;
  color: #fff;
}
.monthly-copy p:not(.band-eyebrow) {
  margin-top: 26px;
  font-size: 16px;
  font-weight: 300;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.82);
  word-break: keep-all;
}
.monthly-slide-nav {
  position: absolute;
  right: 34px;
  bottom: 70px;
  z-index: 3;
  display: flex;
  align-items: center;
  gap: 12px;
  color: rgba(255, 255, 255, 0.76);
}
.monthly-nav-current,
.monthly-nav-total {
  min-width: 18px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.08em;
  line-height: 1;
}
.monthly-nav-total {
  color: rgba(255, 255, 255, 0.42);
}
.monthly-nav-track {
  display: flex;
  align-items: center;
  width: 112px;
  height: 18px;
}
.monthly-slide-nav button {
  position: relative;
  flex: 1;
  height: 18px;
  padding: 0;
  border: 0;
  background: transparent;
  cursor: pointer;
}
.monthly-slide-nav button span {
  position: absolute;
  left: 0;
  right: 0;
  top: 50%;
  display: block;
  width: 100%;
  height: 1px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.28);
  transform: translateY(-50%);
  transition: height 0.25s ease, background 0.25s ease, transform 0.25s ease;
}
.monthly-slide-nav button.active span {
  height: 3px;
  background: rgba(255, 255, 255, 0.92);
  transform: translateY(-50%) scaleX(1.04);
}
.monthly-slide-nav button:hover span {
  background: rgba(255, 255, 255, 0.72);
}
.monthly-editor-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.7s ease;
}
.monthly-showcase:hover .monthly-editor-img img {
  transform: scale(1.06);
}
.monthly-editor h3 {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 28px;
  font-weight: 600;
  letter-spacing: 0.08em;
  color: #2c2723;
}
.monthly-pick-ico {
  font-size: 22px;
  color: #c1654b;
  font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
  flex: none;
}
.monthly-editor h3 span {
  margin-left: 4px;
  color: #8a6f55;
}
.monthly-editor {
  position: relative;
  padding-bottom: 34px;
}
.monthly-slider {
  --monthly-slide-width: clamp(214px, 19.4vw, 308px);
  --monthly-slide-gap: 24px;
  width: calc(100% + var(--monthly-slide-width) + var(--monthly-slide-gap));
  gap: 34px;
  margin-top: 34px;
  margin-left: calc((var(--monthly-slide-width) + var(--monthly-slide-gap)) * -1);
  padding: 0 0 14px;
  overflow-x: hidden;
  overflow-y: visible;
}
.monthly-slide-track {
  display: flex;
  gap: var(--monthly-slide-gap);
  align-items: stretch;
  transition: opacity 0.28s ease, transform 0.42s cubic-bezier(0.22, 0.61, 0.36, 1);
  will-change: transform;
}
.monthly-editor-img {
  flex: 0 0 var(--monthly-slide-width);
  aspect-ratio: 1.28 / 1;
  border-radius: 14px;
  overflow: hidden;
  background: #eee7df;
  box-shadow: 0 6px 14px rgba(58, 43, 31, 0.045);
}
.monthly-editor-img:first-child {
  box-shadow: 0 8px 18px rgba(58, 43, 31, 0.08);
}
.monthly-editor-img.is-hidden {
  display: none;
}
.monthly-editor-info {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 34px;
  margin-top: 14px;
}
.monthly-editor-info b {
  display: block;
  margin-bottom: 10px;
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 0.12em;
  color: #111;
}
.monthly-editor-info p {
  font-size: 14px;
  font-weight: 400;
  line-height: 1.75;
  color: #5f5a55;
  word-break: keep-all;
}
.monthly-editor-info .monthly-rating {
  font-size: 17px;
  font-weight: 500;
  line-height: 1.3;
  color: #4b4641;
}
.monthly-editor-info .monthly-rating span {
  margin-left: 4px;
  font-size: 15px;
  font-weight: 400;
  color: #77706a;
}
.monthly-arrow {
  position: absolute;
  right: 0;
  bottom: 42px;
  font-style: normal;
}
.monthly-showcase,
.monthly-main,
.monthly-editor-img {
  transition: box-shadow 0.3s, transform 0.3s;
}
@media (max-width: 1100px) {
  .monthly-showcase { grid-template-columns: 1fr; gap: 54px; }
  .monthly-main { max-width: 760px; }
  .monthly-slider {
    width: 100%;
    margin-left: 0;
  }
}
@media (max-width: 680px) {
  body.sub:has(.journal-feature) .sub-section > .inner {
    padding-left: 24px;
    padding-right: 24px;
  }
  .best-band { padding: 52px 24px 64px; }
  .monthly-main {
    min-height: 470px;
    padding: 42px 30px;
    overflow: hidden;
  }
  .monthly-copy {
    left: 30px;
    right: 30px;
    max-width: none;
  }
  .monthly-slide-nav {
    right: 28px;
    bottom: 34px;
  }
  .monthly-nav-track { width: 92px; }
  .monthly-slider {
    --monthly-slide-width: min(76vw, 280px);
    width: 100%;
    max-width: calc(100vw - 48px);
    margin-left: 0;
  }
  .monthly-editor-info { grid-template-columns: 1fr; gap: 22px; }
  .monthly-editor h3 { font-size: 24px; }
  .monthly-arrow { right: 4px; }
}
/* 모든 아티클 - 균등 4-up (필터 시 크기 통일) */
.journal-grid.uniform .journal-card:nth-child(1),
.journal-grid.uniform .journal-card:nth-child(2) { grid-column: span 3; }
.journal-grid.uniform .journal-card:nth-child(1) .thumb,
.journal-grid.uniform .journal-card:nth-child(2) .thumb { height: 230px; border-radius: 16px; }
.journal-grid.uniform .journal-card:nth-child(1) h3,
.journal-grid.uniform .journal-card:nth-child(2) h3 { margin-top: 12px; font-size: 19px; font-weight: 500; }
.journal-grid.uniform .journal-card:nth-child(1) p,
.journal-grid.uniform .journal-card:nth-child(2) p { font-size: 14px; -webkit-line-clamp: 2; max-width: none; }
/* 상세 '이어서 읽기' - 균등 3열 1행 */
.journal-grid.related .journal-card,
.journal-grid.related .journal-card:nth-child(1),
.journal-grid.related .journal-card:nth-child(2) { grid-column: span 4; }
.journal-grid.related .journal-card:nth-child(1) .thumb,
.journal-grid.related .journal-card:nth-child(2) .thumb { height: 230px; border-radius: 16px; }
.journal-grid.related .journal-card:nth-child(1) h3,
.journal-grid.related .journal-card:nth-child(2) h3 { margin-top: 12px; font-size: 19px; font-weight: 500; }
.journal-grid.related .journal-card:nth-child(1) p,
.journal-grid.related .journal-card:nth-child(2) p { font-size: 14px; -webkit-line-clamp: 2; max-width: none; }
.journal-card .date { margin-top: 16px; font-size: 13px; color: #aaa; display: flex; align-items: center; justify-content: space-between; }
.journal-card .read-arrow {
  font-style: normal;
  font-size: 18px;
  color: #2c2723;
  margin-right: 5px;
  transition: transform 0.3s, color 0.3s;
}
.journal-card:hover .read-arrow { transform: translateX(6px); color: #8a6f55; }

/* 저널 상단 피처드 - 화면 전체 폭 + 고정 배경(패럴럭스) */
body.sub { overflow-x: hidden; }
.journal-feature {
  position: relative;
  width: 100vw;
  margin-left: calc(50% - 50vw);
  height: 560px;
  border-radius: 0;
  overflow: hidden;
  margin-bottom: 0;
  display: flex;
  align-items: flex-end;
  color: #fff;
  background: url('../images/section_04_2.png') center / cover no-repeat;
  background-attachment: fixed;
}
.journal-feature .jf-bg { display: none; }
.journal-feature .jf-content { max-width: 1400px; margin: 0 auto; }
.journal-feature::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(20, 16, 12, 0.85), rgba(20, 16, 12, 0.05) 65%);
}
.journal-feature .pick {
  position: absolute;
  top: 30px;
  right: max(24px, calc(50% - 700px));
  z-index: 2;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 11px 20px;
  border-radius: 50px;
  background: #fff;
  color: #2c2723;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.14em;
  box-shadow: 0 10px 26px rgba(0, 0, 0, 0.25);
}
.journal-feature .pick::before {
  content: "★";
  font-size: 11px;
  color: #8a6f55;
}
.journal-feature .jf-content {
  position: relative;
  z-index: 1;
  width: 100%;
  padding: 48px 0 42px;
}
.journal-feature .cat { color: #e7d8c6; font-weight: 600; letter-spacing: 0.16em; font-size: 13px; }
.journal-feature h2 {
  margin-top: 14px;
  font-size: 38px;
  font-weight: 600;
  color: #fff;
  line-height: 1.3;
  transition: color 0.2s;
}
.journal-feature:hover h2 { color: #e7d8c6; }
.journal-feature h2 br { display: none; }
.journal-feature p { margin-top: 16px; max-width: 620px; font-size: 16px; color: rgba(255, 255, 255, 0.82); line-height: 1.8; word-break: keep-all; }
.journal-feature .jf-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  margin-top: 28px;
  padding-top: 20px;
  border-top: 1px solid rgba(255, 255, 255, 0.28);
}
.journal-feature .jf-foot .date { margin: 0; font-size: 14px; color: rgba(255, 255, 255, 0.65); }
.journal-feature .jf-more {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 14px;
  font-weight: 600;
  color: #fff;
}
.journal-feature .jf-more em { font-style: normal; transition: transform 0.25s; }
.journal-feature:hover .jf-more em { transform: translateX(4px); }

/* ---------- 스테이 상세 ---------- */
.detail-wrap { padding-top: 130px; }
.detail-gallery {
  position: relative;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-template-rows: repeat(2, 1fr);
  gap: 8px;
  height: 520px;
  margin-bottom: 60px;
  border-radius: 20px;
  overflow: hidden;
  border-radius: 20px;
  overflow: hidden;
}
.detail-gallery .g-item { overflow: hidden; }
.detail-gallery .g-main { grid-column: 1 / 3; grid-row: 1 / 3; }
.detail-gallery img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  cursor: pointer;
  transition: transform 0.5s ease, filter 0.3s;
}
.detail-gallery .g-item:hover img { transform: scale(1.03); filter: brightness(0.92); }
.g-all {
  position: absolute;
  right: 18px;
  bottom: 18px;
  z-index: 2;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 18px;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(4px);
  border: 1px solid rgba(44, 39, 35, 0.25);
  border-radius: 10px;
  font-size: 13px;
  font-weight: 600;
  color: #2c2723;
  cursor: pointer;
  transition: background 0.2s, transform 0.2s;
}
.g-all:hover { background: #fff; transform: translateY(-1px); }
.g-all svg { width: 15px; height: 15px; }

/* 갤러리 라이트박스 */
.g-lightbox {
  position: fixed;
  inset: 0;
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(15, 12, 10, 0.94);
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.25s;
}
.g-lightbox.open { opacity: 1; visibility: visible; }
.g-lightbox figure { max-width: min(1080px, 86vw); text-align: center; }
.g-lightbox img {
  max-width: 100%;
  max-height: 78vh;
  border-radius: 12px;
  object-fit: contain;
}
.g-lightbox figcaption { margin-top: 16px; font-size: 13px; letter-spacing: 0.08em; color: rgba(255, 255, 255, 0.65); }
.g-lightbox .g-close {
  position: absolute;
  top: 24px;
  right: 28px;
  width: 42px;
  height: 42px;
  border: none;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
  color: #fff;
  font-size: 16px;
  cursor: pointer;
  transition: background 0.2s;
}
.g-lightbox .g-close:hover { background: rgba(255, 255, 255, 0.25); }
.g-lightbox .g-nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 50px;
  height: 50px;
  border: none;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
  font-size: 26px;
  line-height: 1;
  cursor: pointer;
  transition: background 0.2s;
}
.g-lightbox .g-nav:hover { background: rgba(255, 255, 255, 0.22); }
.g-lightbox .g-nav.prev { left: 26px; }
.g-lightbox .g-nav.next { right: 26px; }
.detail-body { display: grid; grid-template-columns: 1.6fr 1fr; gap: 60px; align-items: start; }
.detail-info .badge { background: #8a6f55; border: none; }
.detail-info h1 { margin-top: 20px; font-size: 36px; font-weight: 600; color: #2c2723; }
.detail-info .loc { margin-top: 12px; font-size: 15px; color: #888; }
.detail-info .lead {
  margin-top: 28px;
  padding-top: 28px;
  border-top: 1px solid #eee;
  font-size: 16px;
  line-height: 1.9;
  color: #555;
}
.detail-info h4 { margin: 40px 0 18px; font-size: 18px; color: #2c2723; font-weight: 600; }
.amenities { display: flex; flex-wrap: wrap; gap: 12px; }
.amenities span {
  padding: 9px 18px;
  border: 1px solid #e3ded8;
  border-radius: 50px;
  font-size: 13px;
  color: #6a635c;
}
.detail-thumbs { display: flex; gap: 10px; margin-top: 30px; }
.detail-thumbs img { width: 84px; height: 84px; border-radius: 12px; object-fit: cover; }

/* 리뷰 */
.review-summary {
  display: grid;
  grid-template-columns: 150px 1fr;
  gap: 36px;
  align-items: center;
  margin-top: 24px;
  padding: 28px 32px;
  background: #f7f3ef;
  border-radius: 16px;
}
.review-summary .score { text-align: center; }
.review-summary .score strong { display: block; font-family: 'Wave', sans-serif; font-size: 44px; font-weight: normal; line-height: 1; color: #2c2723; }
.review-summary .score .stars { margin-top: 9px; font-size: 14px; letter-spacing: 2px; color: #d9a441; }
.review-summary .score span { display: block; margin-top: 7px; font-size: 12.5px; color: #8b837a; }
.score-bars { list-style: none; display: grid; gap: 13px; }
.score-bars li { display: flex; align-items: center; gap: 12px; font-size: 13px; color: #756d64; }
.score-bars li span { flex: 0 0 60px; }
.score-bars .bar { flex: 1; height: 6px; background: #e8e0d6; border-radius: 4px; overflow: hidden; }
.score-bars .bar i { display: block; height: 100%; background: #8a6f55; border-radius: 4px; }
.score-bars b { flex: 0 0 28px; text-align: right; font-weight: 600; color: #2c2723; }
.review-list { list-style: none; margin-top: 14px; }
.review-list li { padding: 24px 0; border-bottom: 1px solid #f1ece7; }
.review-list li:last-child { border-bottom: none; }
.review-top { display: flex; align-items: center; gap: 13px; }
.review-avatar {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  background: #e8ddd1;
  color: #8a6f55;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 15px;
  font-weight: 600;
}
.review-who b { display: block; font-size: 14.5px; font-weight: 600; color: #2c2723; }
.review-who span { display: block; margin-top: 3px; font-size: 12px; color: #aaa; }
.review-stars { margin-left: auto; font-size: 13px; letter-spacing: 2px; color: #d9a441; }
.review-list p { margin-top: 14px; font-size: 14.5px; line-height: 1.8; color: #555; word-break: keep-all; }
.review-more {
  width: 100%;
  margin-top: 10px;
  padding: 13px;
  border: 1px solid #ddd5cb;
  border-radius: 10px;
  background: #fff;
  font-size: 14px;
  color: #2c2723;
  cursor: pointer;
  transition: background 0.2s;
}
.review-more:hover { background: #f7f3ef; }
@media (max-width: 680px) {
  .review-summary { grid-template-columns: 1fr; gap: 22px; }
}

/* 예약 박스 */
.booking-box {
  position: sticky;
  top: 110px;
  border: 1px solid #eee;
  border-radius: 18px;
  padding: 30px;
  box-shadow: 0 14px 40px rgba(120, 100, 85, 0.1);
}
.booking-box .price { font-size: 26px; font-weight: 600; color: #2c2723; }
.booking-box .price span { font-size: 14px; font-weight: 400; color: #999; }
.booking-field { margin-top: 18px; }
.booking-field label { display: block; font-size: 13px; color: #888; margin-bottom: 7px; }
.booking-field input, .booking-field select {
  width: 100%;
  padding: 13px 14px;
  border: 1px solid #e0dbd5;
  border-radius: 10px;
  font-size: 14px;
  color: #333;
  background: #fff;
}
/* 인원 스테퍼 */
.guest-stepper {
  border: 1px solid #e0dbd5;
  border-radius: 10px;
  padding: 6px 14px;
}
.guest-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 0;
}
.guest-row + .guest-row { border-top: 1px solid #f1ece7; }
.guest-label .g-title { display: block; font-size: 14px; color: #2c2723; font-weight: 500; }
.guest-label .g-desc { display: block; font-size: 12px; color: #aaa; margin-top: 2px; }
.stepper { display: flex; align-items: center; gap: 14px; }
.step-btn {
  width: 32px;
  height: 32px;
  border: 1px solid #d8d1c9;
  border-radius: 50%;
  background: #fff;
  color: #2c2723;
  font-size: 18px;
  line-height: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: border-color 0.2s, color 0.2s, opacity 0.2s;
}
.step-btn:hover:not(:disabled) { border-color: #8a6f55; color: #8a6f55; }
.step-btn:disabled { opacity: 0.35; cursor: not-allowed; }
.step-val { min-width: 18px; text-align: center; font-size: 15px; color: #2c2723; }

.btn-primary {
  display: block;
  width: 100%;
  margin-top: 24px;
  padding: 16px;
  background: #2c2723;
  color: #fff;
  border-radius: 10px;
  text-align: center;
  font-size: 15px;
  letter-spacing: 0.05em;
  transition: background 0.3s;
  cursor: pointer;
}
.btn-primary:hover { background: #8a6f55; }
.booking-note { margin-top: 14px; font-size: 12px; color: #aaa; text-align: center; }

/* ---------- 캘린더(날짜 선택) ---------- */
.date-trigger {
  width: 100%;
  text-align: left;
  padding: 13px 14px;
  border: 1px solid #e0dbd5;
  border-radius: 10px;
  font-size: 14px;
  color: #333;
  background: #fff;
  cursor: pointer;
  transition: border-color 0.2s;
}
.date-trigger:hover { border-color: #8a6f55; }
.date-trigger.placeholder { color: #aaa; }
.calendar {
  display: none;
  margin-top: 12px;
  border: 1px solid #eee;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 10px 30px rgba(120, 100, 85, 0.08);
}
.calendar.open { display: block; }
.cal-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}
.cal-head button {
  background: none;
  border: none;
  cursor: pointer;
  font-size: 18px;
  color: #555;
  padding: 4px 10px;
  border-radius: 8px;
}
.cal-head button:hover { background: #f1ece7; }
.cal-head button:disabled { color: #ddd; cursor: default; background: none; }
.cal-title { font-size: 15px; font-weight: 600; color: #2c2723; }
.cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px; }
.cal-grid .dow { text-align: center; font-size: 11px; color: #aaa; padding: 6px 0; }
.cal-day {
  aspect-ratio: 1 / 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  border-radius: 8px;
  cursor: pointer;
  color: #444;
  transition: background 0.15s;
}
.cal-day:hover { background: #f1ece7; }
.cal-day.disabled { color: #dcd7d1; cursor: default; }
.cal-day.disabled:hover { background: none; }
.cal-day.inrange { background: #efe6dd; color: #8a6f55; border-radius: 0; }
.cal-day.start, .cal-day.end { background: #2c2723; color: #fff; }
.cal-day.start { border-radius: 8px 0 0 8px; }
.cal-day.end { border-radius: 0 8px 8px 0; }
.cal-day.single { background: #2c2723; color: #fff; border-radius: 8px; }
.price-summary {
  margin-top: 18px;
  padding-top: 18px;
  border-top: 1px solid #eee;
  font-size: 14px;
  color: #666;
}
.price-summary .row { display: flex; justify-content: space-between; margin-bottom: 8px; }
.price-summary .total { font-size: 17px; font-weight: 600; color: #2c2723; padding-top: 10px; border-top: 1px solid #eee; }

/* ---------- 예약 진행 페이지 ---------- */
.booking-layout { display: grid; grid-template-columns: 1.5fr 1fr; gap: 50px; align-items: start; padding-top: 130px; }
.booking-main h1 { font-size: 30px; font-weight: 600; color: #2c2723; margin-bottom: 8px; }
.booking-main .step { font-size: 14px; color: #8a6f55; letter-spacing: 0.05em; margin-bottom: 30px; }
.booking-block { border: 1px solid #eee; border-radius: 16px; padding: 28px 30px; margin-bottom: 24px; }
.booking-block h3 { font-size: 18px; font-weight: 600; color: #2c2723; margin-bottom: 20px; }
.booking-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
.booking-grid .full { grid-column: 1 / 3; }
.booking-grid label { display: block; font-size: 13px; color: #888; margin-bottom: 7px; }
.booking-grid input, .booking-grid select, .booking-grid textarea {
  width: 100%;
  padding: 13px 14px;
  border: 1px solid #e0dbd5;
  border-radius: 10px;
  font-size: 14px;
  font-family: inherit;
}
.booking-grid textarea { min-height: 90px; resize: vertical; }
.booking-grid input:focus, .booking-grid select:focus, .booking-grid textarea:focus { outline: none; border-color: #8a6f55; }
.pay-methods { display: flex; flex-direction: column; gap: 10px; }
.pay-methods label {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 15px 18px;
  border: 1px solid #e0dbd5;
  border-radius: 10px;
  cursor: pointer;
  font-size: 15px;
  color: #444;
  transition: border-color 0.2s, background 0.2s;
}
.pay-methods label:hover { border-color: #8a6f55; }
.pay-methods input:checked + span { font-weight: 600; color: #2c2723; }

/* 예약 요약(사이드) */
.summary-card {
  position: sticky;
  top: 110px;
  border: 1px solid #eee;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 14px 40px rgba(120, 100, 85, 0.1);
}
.summary-card .thumb { height: 180px; }
.summary-card .thumb img { width: 100%; height: 100%; object-fit: cover; }
.summary-card .body { padding: 24px; }
.summary-card .badge { background: #8a6f55; border: none; }
.summary-card h3 { margin-top: 14px; font-size: 20px; font-weight: 600; color: #2c2723; }
.summary-card .loc { margin-top: 6px; font-size: 13px; color: #999; }
.summary-row { display: flex; justify-content: space-between; font-size: 14px; color: #666; margin-top: 14px; }
.summary-card .divide { height: 1px; background: #eee; margin: 20px 0; }
.summary-total { display: flex; justify-content: space-between; font-size: 19px; font-weight: 600; color: #2c2723; }

/* 예약 완료 */
.complete-wrap { padding: 180px 0 120px; text-align: center; }
.complete-icon {
  width: 84px;
  height: 84px;
  margin: 0 auto 30px;
  border-radius: 50%;
  background: #efe6dd;
  display: flex;
  align-items: center;
  justify-content: center;
}
.complete-icon svg { width: 40px; height: 40px; stroke: #8a6f55; }
.complete-wrap h1 { font-size: 32px; font-weight: 600; color: #2c2723; }
.complete-wrap .lead { margin-top: 16px; font-size: 16px; color: #777; line-height: 1.8; }
.complete-detail {
  max-width: 460px;
  margin: 40px auto 0;
  border: 1px solid #eee;
  border-radius: 16px;
  padding: 30px;
  text-align: left;
}
.complete-detail .row { display: flex; justify-content: space-between; font-size: 15px; margin-bottom: 14px; }
.complete-detail .row:last-child { margin-bottom: 0; }
.complete-detail .row span:first-child { color: #999; }
.complete-detail .row span:last-child { color: #2c2723; font-weight: 500; }
.complete-actions { margin-top: 40px; display: flex; gap: 12px; justify-content: center; }
.btn-outline {
  padding: 15px 36px;
  border: 1px solid #2c2723;
  border-radius: 10px;
  color: #2c2723;
  font-size: 15px;
  transition: all 0.25s;
}
.btn-outline:hover { background: #2c2723; color: #fff; }
.btn-fill {
  padding: 15px 36px;
  background: #2c2723;
  border-radius: 10px;
  color: #fff;
  font-size: 15px;
  transition: background 0.25s;
}
.btn-fill:hover { background: #8a6f55; }

@media (max-width: 1000px) {
  .booking-layout { grid-template-columns: 1fr; }
  .summary-card { position: static; }
}

/* ---------- 아티클(저널 상세) ---------- */
.article-hero { position: relative; height: 520px; color: #fff; display: flex; align-items: flex-end; }
.article-hero img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
.article-hero::after { content: ""; position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.7), transparent 70%); }
.article-hero .inner { position: relative; z-index: 1; padding-bottom: 60px; }
.article-hero .cat { color: #e7d8c6; font-weight: 600; letter-spacing: 0.16em; font-size: 13px; }
.article-hero h1 { margin-top: 16px; font-size: 42px; font-weight: 600; line-height: 1.3; max-width: 760px; }
.article-hero .meta { margin-top: 20px; font-size: 14px; color: rgba(255,255,255,0.8); }
.article-body { max-width: 760px; margin: 0 auto; padding: 80px 0; }
.article-body p { font-size: 17px; line-height: 2; color: #444; margin-bottom: 28px; }
.article-body h2 { font-size: 26px; font-weight: 600; color: #2c2723; margin: 50px 0 22px; }
.article-body img { width: 100%; border-radius: 16px; margin: 20px 0 40px; }
.article-body blockquote {
  margin: 40px 0;
  padding: 8px 0 8px 28px;
  border-left: 3px solid #8a6f55;
  font-size: 21px;
  line-height: 1.6;
  color: #2c2723;
  font-weight: 300;
}

/* ---------- 검색 페이지 ---------- */
.search-hero {
  position: relative;
  padding: 170px 0 86px;
  background:
    radial-gradient(ellipse 70% 90% at 50% -20%, rgba(201, 168, 124, 0.16), transparent 60%),
    #221d18;
  color: #fff;
  text-align: center;
  overflow: hidden;
}
/* 초대형 고스트 타이포 */
.sh-ghost {
  position: absolute;
  left: 50%;
  top: 118px;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  font-family: 'Wave', sans-serif;
  font-size: clamp(110px, 15vw, 220px);
  line-height: 1;
  letter-spacing: 0.04em;
  color: rgba(255, 255, 255, 0.05);
  -webkit-text-stroke: 1px rgba(201, 168, 124, 0.12);
  pointer-events: none;
  white-space: nowrap;
}
.sh-ghost i { font-style: normal; }
.sh-ghost::after {
  content: "";
  display: inline-block;
  width: 3px;
  height: 0.88em;
  margin-left: 14px;
  background: rgba(201, 168, 124, 0.2);
  animation: caret-blink 0.9s steps(1) infinite;
}
.search-hero .inner { position: relative; z-index: 1; }
.sh-eyebrow {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.32em;
  color: #c9a87c;
}
.sh-eyebrow i { display: block; width: 36px; height: 1px; background: rgba(201, 168, 124, 0.5); }
.search-hero h1 { margin-top: 18px; font-size: 38px; font-weight: 600; }
.search-hero h1 em { font-style: normal; color: #c9a87c; }
.search-hero .sh-sub { margin-top: 14px; color: rgba(255, 255, 255, 0.7); }
/* 인기 검색어 칩 */
.sh-keywords {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 9px;
  margin-top: 30px;
}
.sh-keywords > span { margin-right: 5px; font-size: 12px; color: rgba(255, 255, 255, 0.45); letter-spacing: 0.06em; }
.sh-keywords button {
  padding: 9px 16px;
  border: 1px solid rgba(255, 255, 255, 0.22);
  border-radius: 50px;
  background: rgba(255, 255, 255, 0.04);
  color: rgba(255, 255, 255, 0.85);
  font-size: 13px;
  cursor: pointer;
  transition: background 0.25s, border-color 0.25s, color 0.25s;
}
.sh-keywords button:hover { background: #c9a87c; border-color: #c9a87c; color: #221d18; }
/* 하단 지명 마퀴 */
.sh-marquee {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 16px;
  overflow: hidden;
  pointer-events: none;
}
.sh-track {
  display: flex;
  width: max-content;
  animation: sh-roll 50s linear infinite;
}
.sh-track span {
  flex: 0 0 auto;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.34em;
  color: rgba(255, 255, 255, 0.14);
  white-space: nowrap;
}
@keyframes sh-roll {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}
.search-form {
  display: flex;
  max-width: 680px;
  margin: 36px auto 0;
  background: #fff;
  border-radius: 50px;
  overflow: hidden;
}
.search-form input { flex: 1; border: none; padding: 20px 28px; font-size: 16px; color: #333; }
.search-form input:focus { outline: none; }
.search-form button { padding: 0 34px; background: #8a6f55; color: #fff; border: none; cursor: pointer; font-size: 16px; }
.search-keywords { margin-top: 26px; font-size: 14px; color: rgba(255,255,255,0.75); }
.search-keywords a {
  display: inline-block;
  margin: 0 6px;
  padding: 7px 16px;
  border: 1px solid rgba(255,255,255,0.3);
  border-radius: 50px;
  color: #fff;
  transition: background 0.25s;
}
.search-keywords a:hover { background: rgba(255,255,255,0.15); }

/* ---------- 통합 검색 패널 (검색바 + 필터) ---------- */
.search-panel {
  position: relative;
  z-index: 3;
  margin-top: -36px;
  margin-bottom: 44px;
  background: #fff;
  border: 1px solid #eee;
  border-radius: 20px;
  box-shadow: 0 24px 60px rgba(120, 100, 85, 0.12);
  padding: 10px 0;
  overflow: hidden;
}
.search-bar {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 10px 36px 10px 42px;
}
.search-bar .ico { width: 22px; height: 22px; color: #8a6f55; flex: none; }
.search-bar input {
  flex: 1;
  border: none;
  padding: 14px 0;
  font-size: 17px;
  color: #333;
  background: none;
}
.search-bar input::placeholder { color: #b3aca5; }
.search-bar input:focus { outline: none; }
.search-bar .search-go {
  flex: none;
  padding: 13px 32px;
  background: #2c2723;
  color: #fff;
  border: none;
  border-radius: 50px;
  font-size: 15px;
  letter-spacing: 0.02em;
  cursor: pointer;
  transition: background 0.25s;
}
.search-bar .search-go:hover { background: #8a6f55; }

/* 검색바 안 상세필터 토글 (검색 버튼과 한 줄 정렬) */
.search-bar .bar-divider { flex: none; width: 1px; height: 26px; background: #ececec; margin: 0 2px; }
.filter-toggle {
  flex: none;
  display: inline-flex;
  align-items: center;
  gap: 7px;
  background: none;
  border: none;
  cursor: pointer;
  font-size: 14px;
  font-weight: 500;
  color: #2c2723;
  padding: 8px 8px;
  white-space: nowrap;
}
.filter-toggle .ico-sm { width: 17px; height: 17px; color: #8a6f55; flex: none; }
.filter-toggle .arrow { width: 14px; height: 14px; color: #999; flex: none; transition: transform 0.3s; }
.filter-toggle.open .arrow { transform: rotate(180deg); }
.filter-count { flex: none; font-size: 13px; color: #8a6f55; white-space: nowrap; margin-right: 2px; }

/* 펼침/접힘 */
.search-filters {
  max-height: 0;
  opacity: 0;
  overflow: hidden;
  transition: max-height 0.4s ease, opacity 0.3s ease;
}
.search-filters.open {
  max-height: 760px;
  opacity: 1;
}
/* 좌(필터 항목) / 우(달력) 2단 배치 */
.filters-cols {
  display: grid;
  grid-template-columns: 1fr 340px;
  gap: 44px;
  align-items: start;
  background: #faf8f5;
  padding: 22px 42px;
}
.filters-left { padding-left: 0; }
.filters-right { padding-top: 14px; }
.filters-right .calendar {
  display: block;
  margin-top: 0;
  box-shadow: none;
  border: 1px solid #eee;
  background: #fff;
}
.filters-right .cal-day { font-size: 14px; }
@media (max-width: 880px) {
  .filters-cols { grid-template-columns: 1fr; }
  .filters-right { max-width: 360px; }
}
.filter-group {
  display: flex;
  align-items: flex-start;
  gap: 24px;
  padding: 11px 0;
}
.filter-group .glabel {
  flex: 0 0 70px;
  padding-top: 9px;
  font-size: 14px;
  font-weight: 600;
  color: #2c2723;
}
.filter-group .chips { display: flex; flex-wrap: wrap; gap: 10px; }
.filter-group .date-field { width: 100%; max-width: 340px; }
.chip {
  padding: 9px 18px;
  border: 1px solid #e0dbd5;
  border-radius: 50px;
  font-size: 14px;
  color: #555;
  background: #fff;
  cursor: pointer;
  transition: all 0.2s;
}
.chip:hover { border-color: #8a6f55; color: #8a6f55; }
.chip.active { background: #2c2723; border-color: #2c2723; color: #fff; }
.filter-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 14px;
  padding: 4px 42px 10px;
}
.filter-reset {
  background: none;
  border: none;
  font-size: 14px;
  color: #999;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 6px;
}
.filter-reset:hover { color: #8a6f55; }

/* ---------- 로그인 ---------- */
.auth-wrap {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 140px 20px 80px;
  background: #f7f3ef;
}
.auth-card {
  width: 100%;
  max-width: 420px;
  background: #fff;
  border-radius: 20px;
  padding: 48px 44px;
  box-shadow: 0 20px 60px rgba(120, 100, 85, 0.12);
}
.auth-card .logo-mark { text-align: center; margin-bottom: 10px; }
.auth-card .logo-mark img { height: 40px; opacity: 0.5; }
.auth-card h1 { text-align: center; font-size: 22px; font-weight: 600; color: #2c2723; }
.auth-card .sub { text-align: center; margin-top: 8px; font-size: 14px; color: #999; }
.auth-field { margin-top: 22px; }
.auth-field label { display: block; font-size: 13px; color: #888; margin-bottom: 7px; }
.auth-field input {
  width: 100%;
  padding: 14px 16px;
  border: 1px solid #e0dbd5;
  border-radius: 10px;
  font-size: 14px;
}
.auth-field input:focus { outline: none; border-color: #8a6f55; }
.auth-row { display: flex; justify-content: space-between; align-items: center; margin-top: 18px; font-size: 13px; color: #888; }
.auth-row a { color: #8a6f55; }
/* 탭(아이디/비밀번호 찾기) */
.auth-tabs { display: flex; gap: 5px; margin-top: 24px; background: #f4f0eb; padding: 5px; border-radius: 12px; }
.auth-tabs button {
  flex: 1;
  padding: 11px;
  border: none;
  background: none;
  border-radius: 9px;
  font-size: 14px;
  color: #8b837a;
  cursor: pointer;
  transition: background 0.2s, color 0.2s, box-shadow 0.2s;
}
.auth-tabs button.active { background: #fff; color: #2c2723; font-weight: 600; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
.auth-pane { display: none; }
.auth-pane.active { display: block; }
.auth-hint { margin-top: 16px; font-size: 13px; line-height: 1.6; color: #aaa; text-align: center; }
.auth-result {
  margin-top: 20px;
  padding: 18px;
  border-radius: 12px;
  background: #f7f3ef;
  font-size: 14px;
  color: #3f3a35;
  text-align: center;
  line-height: 1.6;
}
.auth-result strong { color: #8a6f55; }
.auth-agree { display: flex; align-items: flex-start; gap: 9px; margin-top: 22px; font-size: 13px; line-height: 1.5; color: #777; cursor: pointer; }
.auth-agree input { width: auto; margin-top: 2px; }
.auth-agree a { color: #8a6f55; text-decoration: underline; }
.auth-divider { margin: 28px 0; text-align: center; font-size: 12px; color: #bbb; position: relative; }
.auth-divider::before, .auth-divider::after { content: ""; position: absolute; top: 50%; width: 38%; height: 1px; background: #eee; }
.auth-divider::before { left: 0; }
.auth-divider::after { right: 0; }
.social-login { display: flex; flex-direction: column; gap: 10px; }
.social-login button {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 9px;
  padding: 14px;
  border: 1px solid #e0dbd5;
  border-radius: 10px;
  background: #fff;
  font-size: 14px;
  font-weight: 500;
  color: #444;
  cursor: pointer;
  transition: filter 0.2s, box-shadow 0.2s;
}
.social-login .social-ico {
  position: absolute;
  left: 16px;
  display: inline-flex;
  width: 18px;
  height: 18px;
}
.social-login .social-ico svg { width: 100%; height: 100%; }
.social-login button:hover { filter: brightness(0.96); box-shadow: 0 4px 14px rgba(0,0,0,0.06); }
/* 브랜드 컬러 */
.social-login .kakao { background: #FEE500; border-color: #FEE500; color: #191600; }
.social-login .naver { background: #03C75A; border-color: #03C75A; color: #fff; }
.social-login .google { background: #fff; border-color: #dadce0; color: #3c4043; }
.auth-foot { margin-top: 26px; text-align: center; font-size: 14px; color: #888; }
.auth-foot a { color: #8a6f55; font-weight: 500; }

/* ---------- 문의(contact) ---------- */
.contact-tabs {
  display: flex;
  gap: 8px;
  border-bottom: 1px solid #eee;
  margin-bottom: 50px;
}
.contact-tabs button {
  padding: 16px 28px;
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  font-size: 16px;
  color: #999;
  cursor: pointer;
  transition: all 0.25s;
}
.contact-tabs button.active { color: #2c2723; border-color: #8a6f55; font-weight: 600; }
.contact-panel { display: none; }
.contact-panel.active { display: block; }
.contact-intro { margin-bottom: 36px; }
.contact-intro h2 { font-size: 26px; font-weight: 600; color: #2c2723; }
.contact-intro p { margin-top: 14px; font-size: 15px; color: #777; line-height: 1.8; }
.contact-form { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; }
.contact-form .full { grid-column: 1 / 3; }
.contact-form label { display: block; font-size: 13px; color: #888; margin-bottom: 7px; }
.contact-form input, .contact-form select, .contact-form textarea {
  width: 100%;
  padding: 14px 16px;
  border: 1px solid #e0dbd5;
  border-radius: 10px;
  font-size: 14px;
  font-family: inherit;
}
.contact-form textarea { min-height: 160px; resize: vertical; }
.contact-form input:focus, .contact-form textarea:focus, .contact-form select:focus { outline: none; border-color: #8a6f55; }
.contact-form .btn-primary { grid-column: 1 / 3; width: auto; justify-self: start; padding: 16px 60px; }

/* ---------- 프로모션 ---------- */
/* 상단 피처드 배너 */
/* 섹션 인트로 */

.promo-feature {
  position: relative;
  height: 440px;
  border-radius: 24px;
  overflow: hidden;
  color: #fff;
  display: flex;
  align-items: flex-end;
  margin-bottom: 36px;
}
.promo-feature img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.8s ease; }
.promo-feature:hover img { transform: scale(1.04); }
.promo-feature::after { content: ""; position: absolute; inset: 0; background: linear-gradient(105deg, rgba(0,0,0,0.72) 8%, rgba(0,0,0,0.12) 72%); }
.promo-feature .body { position: relative; z-index: 1; padding: 54px; max-width: 600px; }
.promo-feature .tag { display: inline-block; padding: 7px 16px; border: 1px solid rgba(255,255,255,0.6); border-radius: 50px; font-size: 12px; letter-spacing: 0.08em; margin-bottom: 18px; }
.promo-feature h2 { font-size: 40px; font-weight: 600; line-height: 1.3; }
.promo-feature p { margin-top: 16px; font-size: 16px; color: rgba(255,255,255,0.85); line-height: 1.7; }
.promo-feature .cta { display: inline-flex; align-items: center; gap: 8px; margin-top: 28px; padding: 13px 28px; background: #fff; color: #2c2723; border-radius: 50px; font-size: 14px; font-weight: 500; transition: gap 0.25s, background 0.25s; }
.promo-feature .cta:hover { gap: 14px; background: #efe6dd; }

/* 리스트 */
.promo-list { display: flex; flex-direction: column; gap: 26px; }
.promo-card {
  display: grid;
  grid-template-columns: 380px 1fr;
  gap: 44px;
  align-items: center;
  background: #fff;
  border: 1px solid #efe9e3;
  border-radius: 20px;
  overflow: hidden;
  transition: box-shadow 0.35s, transform 0.35s;
}
.promo-card:hover { box-shadow: 0 22px 50px rgba(120, 100, 85, 0.16); transform: translateY(-5px); }
.promo-card .thumb { position: relative; height: 280px; overflow: hidden; }
.promo-card .thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.7s ease; }
.promo-card:hover .thumb img { transform: scale(1.06); }
.promo-card .discount {
  position: absolute; top: 16px; left: 16px;
  display: inline-flex; align-items: center;
  padding: 7px;
  border-radius: 50px;
  background: rgba(255, 255, 255, 0.94);
  backdrop-filter: blur(6px);
  color: #2c2723;
  box-shadow: 0 8px 22px rgba(0, 0, 0, 0.14);
  transition: padding 0.35s ease;
}
.promo-card .discount:hover { padding-right: 18px; }
.promo-card .discount .d-ic {
  display: flex; align-items: center; justify-content: center;
  width: 32px; height: 32px;
  border-radius: 50%;
  background: #8a6f55; color: #fff;
  font-size: 18px;
}
.promo-card .discount .d-txt {
  max-width: 0;
  margin-left: 0;
  opacity: 0;
  overflow: hidden;
  white-space: nowrap;
  transition: max-width 0.4s ease, opacity 0.25s ease 0.08s, margin-left 0.4s ease;
}
.promo-card .discount:hover .d-txt { max-width: 100px; margin-left: 10px; opacity: 1; }
.promo-card .discount .d-txt b { display: block; font-size: 13px; font-weight: 700; line-height: 1.1; letter-spacing: 0.02em; }
.promo-card .discount .d-txt span { display: block; margin-top: 2px; font-size: 10.5px; color: #8b837a; letter-spacing: 0.03em; }

/* 기간 캘린더 아이콘 */
.promo-card .period .material-symbols-outlined,
.pd-other-card .period .material-symbols-outlined { font-size: 16px; color: #b3a290; }
.pd-other-card .period { display: inline-flex; align-items: center; gap: 6px; }
.pd-hero .meta { display: flex; align-items: center; gap: 8px; }
.pd-hero .meta .material-symbols-outlined { font-size: 17px; color: #e7d8c6; }
.promo-card .body { position: relative; padding: 34px 44px 34px 0; }
.promo-card .num { display: none; }
.promo-card .head { display: flex; align-items: center; gap: 8px; }
.promo-card .tag {
  display: inline-block; padding: 6px 14px; background: #efe6dd; color: #8a6f55;
  border-radius: 50px; font-size: 12px; font-weight: 600; letter-spacing: 0.05em;
}
.promo-card .tag.is-hot { background: #8a6f55; color: #fff; }
.promo-card h3 { margin-top: 16px; font-size: 24px; font-weight: 600; color: #2c2723; }
.promo-card p { margin-top: 12px; font-size: 15px; color: #777; line-height: 1.7; }
.promo-card .foot { display: flex; align-items: center; justify-content: space-between; margin-top: 24px; padding-top: 20px; border-top: 1px solid #f1ece7; }
.promo-card .period { display: block; }
.promo-card .period em {
  display: block;
  font-style: normal;
  font-family: 'A2z', sans-serif;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.2em;
  color: #b3a290;
}
.promo-card .period .p-date {
  display: inline-block;
  margin-top: 10px;
  padding: 0 6px;
  font-size: 26px;
  line-height: 1.1;
  color: #2c2723;
  letter-spacing: 0.01em;
  background: linear-gradient(transparent 58%, #f3e3cd 58%); /* 형광펜 하이라이트 */
}
.promo-card .period .left-days {
  display: inline-block;
  margin-left: 10px;
  vertical-align: 3px;
  padding: 4px 11px;
  border-radius: 50px;
  background: #c1654b;
  color: #fff;
  font-family: 'A2z', sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.02em;
}
.promo-card.ended .period .p-date { color: #b0a89e; }
.promo-card .more-arrow {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 11px 22px;
  border: 1px solid #2c2723;
  border-radius: 50px;
  font-size: 13.5px;
  font-weight: 500;
  color: #2c2723;
  transition: gap 0.25s, background 0.25s, color 0.25s;
}
.promo-card:hover .more-arrow { gap: 12px; background: #2c2723; color: #fff; }

/* 이용 안내 */
/* 종료된 프로모션 */
.promo-card.ended { cursor: default; }
.promo-card.ended:hover { transform: none; box-shadow: none; }
.promo-card.ended .thumb img { filter: grayscale(1); opacity: 0.85; }
.promo-card.ended:hover .thumb img { transform: none; }
.ended-chip {
  position: absolute;
  top: 16px;
  left: 16px;
  padding: 8px 16px;
  border-radius: 50px;
  background: rgba(44, 39, 35, 0.82);
  backdrop-filter: blur(4px);
  color: #fff;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.1em;
}
.ended-label { font-size: 13px; color: #b0a89e; }

.promo-notice { margin-top: 0; padding: 40px 0; background: #f7f3ef; border-radius: 0; }
.promo-notice .inner { padding-top: 0; padding-bottom: 0; }
.promo-notice h4 { font-size: 16px; font-weight: 600; color: #2c2723; margin-bottom: 12px; }
.promo-notice ul { list-style: none; }
.promo-notice li { position: relative; padding-left: 16px; font-size: 14px; color: #777; line-height: 1.95; }
.promo-notice li::before { content: "·"; position: absolute; left: 4px; color: #8a6f55; }

/* ---------- 사전예약(pre-order) ---------- */
/* ===================== PRE-ORDER (에디토리얼) ===================== */
.preorder-page .preorder-section > .inner,
.preorder-page #footer > .inner {
  padding-left: 0;
  padding-right: 0;
}
.preorder-section { background: #faf8f5; }
/* 상단 배경 밴드 (브레드크럼 + 헤더 전체) */
.po-hero {
  width: 100vw;
  margin-left: calc(50% - 50vw);
  margin-top: -150px;
  padding: 150px max(24px, calc(50vw - 700px)) 86px;
  background:
    linear-gradient(180deg, rgba(24, 19, 15, 0.88), rgba(24, 19, 15, 0.74) 55%, rgba(24, 19, 15, 0.92)),
    url('../images/section_02_5.png') center / cover no-repeat;
  background-attachment: fixed, fixed;
  margin-bottom: 64px;
}
.po-hero .po-head { border-bottom: none; margin-bottom: 0; }
/* 다크 밴드 위 글자: 흰색에 가깝게 */
.po-hero .breadcrumb,
.po-hero .breadcrumb a { color: rgba(250, 247, 243, 0.55); }
.po-hero .breadcrumb a:hover { color: #c9a87c; }
.po-hero .breadcrumb span { color: rgba(250, 247, 243, 0.3); }
.po-hero .po-eyebrow { color: #c9a87c; }
.po-hero .po-eyebrow i { background: #c9a87c; }
.po-hero .po-head-title { color: #faf7f3; }
.po-hero .po-head-title em { color: #c9a87c; }
.po-hero .po-head-lead { border-left-color: #c9a87c; color: rgba(250, 247, 243, 0.82); }
.po-hero .po-legend li { color: rgba(250, 247, 243, 0.72); }
.po-hero .po-head-stats li { border-left-color: rgba(250, 247, 243, 0.15); }
.po-hero .po-head-stats .st-ic { background: rgba(250, 247, 243, 0.1); color: #c9a87c; }
.po-hero .po-head-stats strong { color: #faf7f3; }
.po-hero .po-head-stats span { color: rgba(250, 247, 243, 0.6); }
/* 헤더 */
.po-head {
  position: relative;
  display: grid;
  grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
  gap: 60px;
  align-items: end;
  padding: 34px 0 58px;
  border-bottom: 1px solid #ece7e1;
  margin-bottom: 88px;
}
.po-head-left,
.po-head-right { position: relative; z-index: 1; }
.po-eyebrow {
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 12px;
  letter-spacing: 0.22em;
  color: #8a6f55;
  font-weight: 600;
}
.po-eyebrow i { display: block; width: 36px; height: 1px; background: #8a6f55; }
.po-head-title {
  margin-top: 26px;
  font-size: 48px;
  line-height: 1.16;
  font-weight: 600;
  letter-spacing: -0.01em;
  color: #2c2723;
}
.po-head-title em { font-style: normal; color: #8a6f55; }
.po-head-right { padding-bottom: 6px; }
.po-head-lead {
  padding-left: 20px;
  border-left: 2px solid #8a6f55;
  font-size: 16px;
  line-height: 1.75;
  color: #6f675f;
  word-break: keep-all;
}
.po-head-stats { display: flex; margin-top: 40px; list-style: none; }
.po-head-stats li {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 13px;
  padding: 0 22px;
  border-left: 1px solid #ece7e1;
}
.po-head-stats li:first-child { padding-left: 0; border-left: none; }
.po-head-stats .st-ic {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 54px;
  height: 54px;
  border-radius: 15px;
  background: #f1e9e0;
  color: #8a6f55;
  font-size: 29px;
}
.po-head-stats strong { display: block; font-size: 25px; font-weight: 700; color: #2c2723; letter-spacing: -0.01em; }
.po-head-stats span { display: block; margin-top: 7px; font-size: 12.5px; color: #8b837a; }
.po-legend { display: flex; gap: 22px; margin-top: 38px; }
.po-legend li { display: inline-flex; align-items: center; gap: 8px; font-size: 13px; color: #8b837a; }
.po-dot { width: 8px; height: 8px; border-radius: 50%; }
.po-dot.open { background: #c1654b; box-shadow: 0 0 0 4px rgba(193, 101, 75, 0.14); }
.po-dot.coming { background: #b9b0a5; box-shadow: 0 0 0 4px rgba(185, 176, 165, 0.18); }

/* 공통: 상태칩 · 인덱스 · D-day */
.po-status {
  position: absolute;
  top: 18px;
  left: 18px;
  z-index: 2;
  padding: 7px 14px;
  border-radius: 50px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.1em;
  color: #fff;
  backdrop-filter: blur(6px);
}
.po-status.open { background: rgba(193, 101, 75, 0.92); }
.po-status.coming { background: rgba(44, 39, 35, 0.62); }
/* 오픈 완료(예약 가능) 상태 */
.po-status.live {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  background: rgba(62, 125, 90, 0.94);
}
.po-status.live::before {
  content: "";
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: #b9efd0;
  animation: po-pulse 1.6s ease-in-out infinite;
}
@keyframes po-pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(0.8); }
}
.po-index {
  position: absolute;
  bottom: 16px;
  right: 18px;
  z-index: 2;
  font-size: 13px;
  letter-spacing: 0.1em;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.92);
}
.po-dday {
  display: inline-flex;
  align-items: center;
  align-self: flex-start;
  padding: 6px 13px;
  border-radius: 8px;
  background: #f4efe9;
  color: #8a6f55;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.04em;
}
.po-dday.soon { background: #f7e9e3; color: #c1654b; }
.po-dday.live { background: #e3f0e8; color: #3e7d5a; }
.po-notify.book { background: #3e7d5a; border-color: #3e7d5a; }
.po-notify.book:hover { background: #346a4c; }
.po-dot.live { background: #c9a87c; box-shadow: 0 0 0 4px rgba(201, 168, 124, 0.16); }

/* 라인업 래퍼: 왼쪽 고정 카드 + 오른쪽 슬라이더 */
.po-lineup {
  display: flex;
  align-items: stretch;
  gap: 38px;
  margin-right: calc(50% - 50vw);
}
.preorder-page .po-lineup {
  margin-right: 0;
}
/* 피처드 카드 - 슬라이더 왼쪽 고정 (스크롤 영향 없음) */
.po-featured {
  position: relative;
  z-index: 2;
  flex: 0 0 520px;
  display: flex;
  flex-direction: column;
  background: #fff;
  border: 1px solid #e7e0d6;
  border-radius: 18px;
  overflow: hidden;
  cursor: pointer;
  margin: 12px 0 24px;
  box-shadow: 0 18px 40px rgba(30, 26, 22, 0.14);
  transition: box-shadow 0.35s, transform 0.35s;
}
.po-featured:hover { transform: translateY(-6px); box-shadow: 0 26px 48px rgba(30, 26, 22, 0.22); }
/* 호버 시 나오는 그린 요소 → 골드 */
.po-featured .po-status.live { background: rgba(176, 138, 94, 0.94); }
.po-featured .po-status.live::before { background: #f3e1c3; }
.po-featured .po-notify.book { background: #b08a5e; border-color: #b08a5e; }
.po-featured .po-notify.book:hover { background: #9a7748; border-color: #9a7748; }
/* 사진이 카드 전체 배경 + 하단 다크 그라데이션 */
.po-featured-media { position: absolute; inset: 0; overflow: hidden; }
.po-featured-media img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
.po-featured:hover .po-featured-media img { transform: scale(1.04); }
.po-featured-media::before {
  content: "";
  position: absolute;
  inset: 0;
  background: rgba(20, 16, 12, 0.36);
  opacity: 1;
  transition: opacity 0.35s ease;
}
.po-featured:hover .po-featured-media::before { opacity: 0; }
.po-featured-media::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(20, 16, 12, 0) 36%, rgba(20, 16, 12, 0.42) 56%, rgba(20, 16, 12, 0.93) 86%);
  opacity: 0;
  transition: opacity 0.35s ease;
}
.po-featured:hover .po-featured-media::after { opacity: 1; }
/* 호버 전: 정가운데 미니멀 커버 */
.po-featured-cover {
  position: absolute;
  inset: 0;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 13px;
  text-align: center;
  pointer-events: none;
  transition: opacity 0.35s ease;
}
.po-featured-cover span {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.34em;
  color: #e9d6b0;
}
.po-featured-cover strong {
  font-size: 38px;
  font-weight: 400;
  color: #fff;
  letter-spacing: -0.01em;
  text-shadow: 0 2px 14px rgba(0, 0, 0, 0.45);
}
.po-featured:hover .po-featured-cover { opacity: 0; }
/* 호버 전엔 상태칩·본문 숨김 */
.po-featured .po-status { opacity: 0; transition: opacity 0.35s ease; }
.po-featured:hover .po-status { opacity: 1; }
.po-featured-body {
  position: relative;
  z-index: 1;
  flex: 1;
  padding: 240px 28px 26px;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  opacity: 0;
  transform: translateY(12px);
  transition: opacity 0.35s ease, transform 0.4s ease;
}
.po-featured:hover .po-featured-body { opacity: 1; transform: none; }
/* 중복 칩 정리: NOW OPEN만 남기고, 안내문은 골드 아이브로로 */
.po-featured .po-dday { display: none; }
.po-featured .po-open-mini {
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 0.08em;
  color: #e9d6b0;
}
.po-featured .po-open-mini strong { color: #e9d6b0; }
.po-featured-body h3 { margin-top: 8px; font-size: 34px; font-weight: 400; color: #fff; letter-spacing: -0.01em; text-shadow: 0 2px 10px rgba(0, 0, 0, 0.35); }
.po-desc { margin-top: 10px; font-size: 13.5px; line-height: 1.7; color: #6f675f; }
.po-featured .po-desc {
  margin-top: 8px;
  color: rgba(255, 255, 255, 0.82);
  text-shadow: 0 1px 8px rgba(0, 0, 0, 0.3);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.po-featured .po-spec { margin-top: 16px; padding: 12px 0 0; border-bottom: none; border-top-color: rgba(255, 255, 255, 0.28); }
.po-featured .po-spec b { color: #fff; }
.po-featured .po-spec .sp-ic { color: #e9d6b0; }
.po-featured .po-spec li + li::before { background: rgba(255, 255, 255, 0.45); }
/* 스펙: 심플 한 줄 */
.po-spec {
  margin-top: 14px;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 6px 0;
  padding: 10px 0;
  border-top: 1px solid #eae2d8;
  border-bottom: 1px solid #eae2d8;
}
.po-spec li {
  display: flex;
  align-items: center;
  gap: 7px;
  padding: 0;
  border: none;
}
.po-spec li + li::before {
  content: "";
  width: 3px;
  height: 3px;
  border-radius: 50%;
  background: #d5cabb;
  margin: 0 14px;
}
.po-spec em { display: none; }
.po-featured .po-foot { padding-top: 36px; }
.po-spec .sp-ic { flex: 0 0 auto; color: #8a6f55; font-size: 17px; }
.po-spec li > div { flex: none; display: flex; align-items: center; }
.po-spec em { flex: 0 0 44px; font-style: normal; font-size: 12px; color: #a89f94; }
.po-spec b { font-size: 13.5px; font-weight: 600; color: #3f3a35; white-space: nowrap; }
.po-featured .po-notify {
  width: 100%;
  min-width: 0;
  justify-content: center;
  padding: 14px;
  font-size: 14px;
}

/* 카드 하단(오픈일 + 알림) */
.po-foot {
  margin-top: auto;
  padding-top: 32px;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16px;
}
.po-open { display: flex; flex-direction: column; gap: 5px; }
.po-open-label { font-size: 12px; letter-spacing: 0.04em; color: #a89f94; }
.po-open strong { font-size: 15px; font-weight: 600; color: #2c2723; font-variant-numeric: tabular-nums; }
.po-notify {
  flex: none;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 22px;
  border: 1px solid #2c2723;
  border-radius: 50px;
  background: #2c2723;
  color: #fff;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: background 0.25s, border-color 0.25s, color 0.25s, gap 0.25s;
}
.po-notify em { font-style: normal; transition: transform 0.25s; }
.po-notify:hover { background: #8a6f55; border-color: #8a6f55; }
.po-notify:hover em { transform: translateX(3px); }
.po-notify.done {
  background: #fff;
  color: #8a6f55;
  border-color: #d8cdc0;
  cursor: default;
}

/* 그리드 카드 */
/* 메인 섹션 1처럼 화면 오른쪽 끝까지 흐르는 가로 슬라이드 */
.po-grid {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: stretch;
  gap: 38px;
  overflow-x: auto;
  overflow-y: hidden;
  padding-left: 16px;
  padding-right: 40px;
  padding-top: 12px;
  padding-bottom: 64px;
  scrollbar-width: none;
}
.po-grid::-webkit-scrollbar { display: none; }
/* 월 구분 숫자 */
.po-month {
  flex: 0 0 auto;
  align-self: stretch;
  margin-top: 26px;
  display: flex;
  flex-direction: column;
  align-items: center;
}
/* 월 마커 아래 정중앙 1px 라인 */
.po-month:not(.po-year)::after {
  content: "";
  width: 1px;
  flex: 1;
  margin-top: 18px;
  background: linear-gradient(180deg, #d8c4a4, rgba(216, 196, 164, 0));
}
.po-month em {
  font-style: normal;
  font-family: 'Wave', sans-serif;
  font-size: 120px;
  line-height: 0.9;
  font-weight: normal;
  color: #2c2723;
  -webkit-text-stroke: 0;
}
.po-month span {
  margin-top: 10px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.3em;
  color: #c9a87c;
}
/* 연도 마커: '26은 카드 상단, 월 네비는 카드 하단에 맞춰 양끝 배치 */
.po-month.po-year { flex: 0 0 180px; align-self: stretch; margin-top: 12px; margin-bottom: 24px; }
.po-month.po-year .po-nav { margin-top: auto; }
.po-month.po-year > span { margin-top: 7px; font-size: 9.5px; letter-spacing: 0.22em; color: #aaa094; }
.po-month.po-year em { font-size: 92px; letter-spacing: 0.01em; color: #c9a87c; }
.po-month.po-year em i { font-style: normal; font-size: 0.45em; vertical-align: 0.75em; margin-right: 2px; color: #b08a5e; }
/* 월 네비게이터 - 에디토리얼 세로 리스트 */
.po-nav {
  margin-top: 24px;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 2px;
}
.po-nav button {
  display: flex;
  align-items: baseline;
  gap: 9px;
  padding: 4px 0;
  border: none;
  background: none;
  text-align: left;
  cursor: pointer;
}
.po-nav button b {
  width: 22px;
  flex: 0 0 22px;
  font-family: 'Wave', sans-serif;
  font-weight: normal;
  font-size: 14px;
  line-height: 1;
  color: #c4b49c;
  transition: color 0.25s;
}
.po-nav button span {
  position: relative;
  top: -1px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.2em;
  line-height: 1;
  color: #9a9189;
  transition: color 0.25s;
}
.po-nav button .dots {
  position: relative;
  top: -1px;
  font-style: normal;
  font-size: 10px;
  letter-spacing: 2px;
  line-height: 1;
  color: #c4b49c;
  transition: color 0.25s;
}
.po-nav button:hover .dots,
.po-nav button.active .dots { color: #8a6f55; }
/* 알림 신청 혜택 - 히어로 하단에 반 걸친 화이트 카드 */
.po-perks {
  position: relative;
  z-index: 3;
  margin-top: -116px;
  margin-bottom: 112px;
  display: flex;
  align-items: center;
  gap: 42px;
  flex-wrap: wrap;
  padding: 30px 56px;
  background: #fff;
  border: 1px solid #ece5da;
  border-radius: 18px;
  box-shadow: 0 20px 44px rgba(70, 52, 35, 0.12);
}
.po-perks .pk-label {
  position: relative;
  padding-right: 42px;
}
/* 절취선 */
.po-perks .pk-label::after {
  content: "";
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  height: 36px;
  border-left: 1px solid #e3d9cb;
}
.po-perks .pk-label em {
  display: block;
  margin-bottom: 5px;
  font-style: normal;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.3em;
  color: #c9a87c;
}
.po-perks strong {
  font-size: 15px;
  font-weight: 700;
  letter-spacing: 0.02em;
  color: #2c2723;
}
.po-perks ul {
  list-style: none;
  display: flex;
  align-items: center;
  gap: 36px;
  flex-wrap: wrap;
}
.po-perks li {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 14px;
  font-weight: 500;
  color: #5f574e;
}
.po-perks li::before {
  content: "\2713";
  display: flex;
  align-items: center;
  justify-content: center;
  width: 19px;
  height: 19px;
  border-radius: 50%;
  background: #f1e7d7;
  font-size: 10px;
  font-weight: 700;
  color: #8a6f55;
}
.po-perks-action {
  margin-left: auto;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  min-width: 214px;
  min-height: 46px;
  padding: 0 24px;
  border: 1px solid #2c2723;
  border-radius: 999px;
  background: #2c2723;
  color: #fff;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.03em;
  transition: background 0.28s, border-color 0.28s, color 0.28s, transform 0.28s;
}
.po-perks-action em {
  font-style: normal;
  font-size: 15px;
  transition: transform 0.28s;
}
.po-perks-action:hover {
  transform: translateY(-2px);
  background: #8a6f55;
  border-color: #8a6f55;
}
.po-perks-action:hover em { transform: translateX(4px); }
.po-perks-action.done {
  background: #c9a87c;
  border-color: #c9a87c;
  color: #2c2723;
}
.po-nav button:hover b { color: #8a6f55; }
.po-nav button:hover span { color: #2c2723; }
.po-nav button.active b { color: #2c2723; }
.po-nav button.active span { color: #2c2723; }
.po-card {
  flex: 0 0 360px;
  display: flex;
  flex-direction: column;
  background: #fff;
  border: 1px solid #efeae4;
  border-radius: 18px;
  overflow: hidden;
  cursor: pointer;
  transition: box-shadow 0.35s, transform 0.35s;
}
.po-card:hover { transform: translateY(-6px); box-shadow: 0 26px 48px rgba(120, 100, 85, 0.13); }
.po-card-media { position: relative; height: 220px; overflow: hidden; }
.po-card-media img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
.po-card:hover .po-card-media img { transform: scale(1.06); }
.po-card-body {
  display: flex;
  flex-direction: column;
  flex: 1;
  padding: 30px 30px 32px;
}
.po-card-body .po-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}
.po-open-mini { font-size: 12px; color: #a89f94; }
.po-open-mini strong { margin-left: 4px; font-size: 12.5px; font-weight: 600; color: #6f675f; font-variant-numeric: tabular-nums; }
.po-card-body h3 { margin-top: 18px; font-size: 18px; font-weight: 600; color: #2c2723; }
.po-card-body p { margin-top: 12px; font-size: 13.5px; line-height: 1.75; color: #756d64; }
.po-card .po-foot { padding-top: 26px; }
.po-card .po-notify {
  width: 100%;
  justify-content: center;
  padding: 12px 16px;
  font-size: 13px;
}

/* ---------- 반응형 ---------- */
@media (max-width: 1100px) {
  .stay-grid { grid-template-columns: repeat(2, 1fr); }
  .detail-body { grid-template-columns: 1fr; }
  .promo-card { grid-template-columns: 1fr; }
  .journal-feature { height: 460px; }
  .journal-feature .jf-content { padding: 36px 32px; }
  .journal-feature h2 { font-size: 30px; }
  .promo-card .thumb { height: 220px; }
  .promo-card .body { padding: 0 30px 30px; }
  /* 프리오더 라인업: 고정 카드 위 / 슬라이더 아래로 적층 */
  .po-lineup { flex-direction: column; gap: 10px; margin-left: 0; padding-left: 0; }
  .po-month.po-year { display: none; }
  .po-featured { flex: none; width: 100%; margin: 12px 0 0; }
  /* 저널: 하이라이트 1-up / 표준 2-up */
  .journal-grid { grid-template-columns: repeat(6, 1fr); gap: 44px 30px; }
  .journal-card { grid-column: span 3; }
  .journal-card:nth-child(1), .journal-card:nth-child(2) { grid-column: span 6; }
  .journal-card:nth-child(1) .thumb, .journal-card:nth-child(2) .thumb { height: 320px; }
  .journal-grid.related .journal-card,
  .journal-grid.related .journal-card:nth-child(1),
  .journal-grid.related .journal-card:nth-child(2),
  .journal-grid.uniform .journal-card:nth-child(1),
  .journal-grid.uniform .journal-card:nth-child(2) { grid-column: span 3; }
  .journal-grid.related .journal-card:nth-child(1) .thumb,
  .journal-grid.related .journal-card:nth-child(2) .thumb,
  .journal-grid.uniform .journal-card:nth-child(1) .thumb,
  .journal-grid.uniform .journal-card:nth-child(2) .thumb { height: 230px; }
}
@media (max-width: 880px) {
  .preorder-page .preorder-section > .inner,
  .preorder-page #footer > .inner {
    padding-left: 24px;
    padding-right: 24px;
  }
  .po-head { grid-template-columns: 1fr; gap: 28px; align-items: start; }
  .po-head-title { font-size: 38px; }
  .po-head-stats li { padding: 0 16px; }
  .po-perks { gap: 24px; padding: 26px 28px; }
  .po-perks-action { margin-left: 0; }
  .po-featured-body { padding: 200px 22px 22px; }
  .po-month em { font-size: 88px; }
}
@media (max-width: 680px) {
  .stay-grid, .contact-form { grid-template-columns: 1fr; }
  .po-card { flex-basis: 300px; }
  .po-month em { font-size: 84px; }
  .po-featured-body h3 { font-size: 21px; }
  .journal-grid { grid-template-columns: 1fr; }
  .journal-card,
  .journal-card:nth-child(1),
  .journal-card:nth-child(2) { grid-column: 1 / -1; }
  .journal-card:nth-child(1) .thumb, .journal-card:nth-child(2) .thumb { height: 240px; }
  .journal-feature { height: auto; min-height: 420px; }
  .journal-feature .jf-content { padding: 28px 24px; }
  .journal-feature h2 { font-size: 25px; }
  .journal-feature .jf-foot { flex-wrap: wrap; }
  .banner-title { font-size: 34px; }
  .po-head-title { font-size: 32px; }
  .po-perks { align-items: stretch; }
  .po-perks .pk-label { width: 100%; padding-right: 0; }
  .po-perks .pk-label::after { display: none; }
  .po-perks ul { gap: 14px; }
  .po-perks-action { width: 100%; }
  .detail-gallery { grid-template-columns: repeat(2, 1fr); grid-template-rows: auto; height: auto; border-radius: 14px; }
  .detail-gallery .g-main { grid-column: 1 / 3; grid-row: auto; height: 260px; }
  .detail-gallery .g-item:not(.g-main) { height: 130px; }
  .detail-gallery .g-item:nth-child(4),
  .detail-gallery .g-item:nth-child(5) { display: none; }
  .g-all { right: 12px; bottom: 12px; padding: 8px 14px; font-size: 12px; }
  .contact-form .full, .contact-form .btn-primary { grid-column: auto; }
}

/* ---------- 프로모션 상세 (promotion-detail) ---------- */
.pd-hero .cat { color: #e7d8c6; font-weight: 600; letter-spacing: 0.16em; font-size: 13px; }
.pd-body { max-width: 860px; margin: 0 auto; padding: 60px 24px 100px; }
.pd-body .breadcrumb { margin-bottom: 40px; }
.pd-body .breadcrumb em { font-style: normal; color: #8a6f55; }
.pd-body h2 { font-size: 25px; font-weight: 600; color: #2c2723; margin: 56px 0 20px; }
.pd-body #pdDesc p { font-size: 16px; line-height: 2; color: #444; margin-bottom: 24px; }

/* 혜택 요약 카드 */
.pd-summary { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
.pd-summary .item { background: #f7f3ef; border-radius: 16px; padding: 26px 18px; text-align: center; }
.pd-summary .item b { display: block; font-size: 21px; font-weight: 700; color: #8a6f55; }
.pd-summary .item span { display: block; margin-top: 8px; font-size: 13px; color: #777; }

/* 참여 방법 스텝 */
.pd-steps { list-style: none; display: grid; gap: 14px; counter-reset: step; }
.pd-steps li {
  position: relative;
  padding: 21px 24px 21px 70px;
  border: 1px solid #ece7e1;
  border-radius: 14px;
  font-size: 15px;
  color: #555;
  line-height: 1.6;
  counter-increment: step;
}
.pd-steps li::before {
  content: counter(step, decimal-leading-zero);
  position: absolute;
  left: 24px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 17px;
  font-weight: 700;
  color: #8a6f55;
}

/* 예약 CTA */
.pd-cta {
  margin-top: 70px;
  padding: 44px 48px;
  background: #2c2723;
  border-radius: 20px;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  flex-wrap: wrap;
}
.pd-cta h3 { font-size: 23px; font-weight: 600; }
.pd-cta p { margin-top: 10px; font-size: 14px; color: rgba(255, 255, 255, 0.7); }
.pd-cta-btns { display: flex; gap: 12px; flex-wrap: wrap; }
.pd-cta .btn {
  display: inline-flex;
  align-items: center;
  padding: 14px 30px;
  background: #fff;
  color: #2c2723;
  border-radius: 50px;
  font-size: 14px;
  font-weight: 500;
  transition: background 0.25s;
}
.pd-cta .btn:hover { background: #efe6dd; }
.pd-cta .btn.ghost { background: transparent; color: #fff; border: 1px solid rgba(255, 255, 255, 0.5); }
.pd-cta .btn.ghost:hover { background: rgba(255, 255, 255, 0.12); }

/* 다른 프로모션 카드 */
.pd-others { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
.pd-other-card { display: block; }
.pd-other-card .thumb { height: 190px; border-radius: 16px; overflow: hidden; }
.pd-other-card .thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
.pd-other-card:hover .thumb img { transform: scale(1.07); }
.pd-other-card .tag { display: inline-block; margin-top: 16px; font-size: 11px; font-weight: 600; letter-spacing: 0.1em; color: #8a6f55; }
.pd-other-card h3 { margin-top: 8px; font-size: 17px; font-weight: 600; color: #2c2723; line-height: 1.45; transition: color 0.2s; }
.pd-other-card:hover h3 { color: #8a6f55; }
.pd-other-card .period { margin-top: 10px; font-size: 12.5px; color: #aaa; }

@media (max-width: 880px) {
  .pd-summary { grid-template-columns: repeat(2, 1fr); }
  .pd-others { grid-template-columns: repeat(2, 1fr); }
  .pd-cta { padding: 34px 30px; }
}
@media (max-width: 560px) {
  .pd-others { grid-template-columns: 1fr; }
}

/* ---------- ABOUT ---------- */
.about-page .sub-section > .inner,
.about-page .ab-gallery > .inner,
.about-page #footer > .inner {
  padding-left: 0;
  padding-right: 0;
}
/* 센터드 스테이트먼트 헤더 */
.ab-head { text-align: center; padding: 30px 0 0; margin-bottom: 90px; }
.ab-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.24em;
  color: #8a6f55;
}
.ab-eyebrow::before,
.ab-eyebrow::after { content: ""; width: 36px; height: 1px; background: #d9cdbd; }
.ab-title {
  margin-top: 22px;
  font-size: 54px;
  font-weight: 500;
  letter-spacing: -0.015em;
  color: #2c2723;
  line-height: 1.2;
}
.ab-title em { font-style: normal; color: #8a6f55; }
.ab-lead {
  max-width: 600px;
  margin: 24px auto 0;
  font-size: 16.5px;
  font-weight: 300;
  line-height: 1.85;
  color: #6f675f;
  word-break: keep-all;
}
.ab-stats {
  position: relative;
  list-style: none;
  display: flex;
  justify-content: center;
  margin-top: 54px;
  padding: 34px 0;
  border-top: 1px solid #ece7e1;
  border-bottom: 1px solid #ece7e1;
}
.ab-stats li { position: relative; padding: 0 64px; }
.ab-stats li + li::before {
  content: "";
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 1px;
  height: 38px;
  background: #ece7e1;
}
.ab-stats strong { display: block; font-family: 'Wave', sans-serif; font-size: 34px; font-weight: normal; color: #2c2723; line-height: 1; letter-spacing: -0.01em; }
.ab-stats strong i { font-style: normal; font-size: 22px; color: #8a6f55; margin-left: 1px; }
.ab-stats span { display: block; margin-top: 10px; font-size: 13px; color: #8b837a; }

@media (max-width: 680px) {
  .ab-title { font-size: 36px; }
  .ab-stats li { padding: 0 22px; }
  .ab-stats strong { font-size: 25px; }
}

.ab-statement {
  position: relative;
  height: 420px;
  border-radius: 24px;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  color: #fff;
  margin-bottom: 0;
}
.ab-statement .jf-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.ab-statement::after {
  content: "";
  position: absolute;
  inset: 0;
  background: rgba(20, 16, 12, 0.5);
}
.ab-statement-body { position: relative; z-index: 1; padding: 0 24px; max-width: 760px; }
.ab-statement .st-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 11px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.26em;
  color: #e7d8c6;
}
.ab-statement .quote {
  position: relative;
  margin-top: 18px;
  font-size: 33px;
  font-weight: 300;
  line-height: 1.5;
  letter-spacing: -0.01em;
}
.ab-statement .quote::before {
  content: "\201C";
  position: absolute;
  top: -58px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 110px;
  line-height: 1;
  font-family: Georgia, serif;
  color: rgba(231, 216, 198, 0.4);
  pointer-events: none;
}
.ab-statement .quote em { font-style: normal; color: #e7d8c6; }
.ab-statement .sub { margin-top: 16px; font-size: 14.5px; font-weight: 200; color: rgba(255, 255, 255, 0.72); }

.ab-sec { margin-top: 90px; margin-bottom: 48px; text-align: left; }
.inner > .ab-sec:first-child { margin-top: 0; }
/* 스테이트먼트 사진이 베이지 밴드 위로 중첩되도록 */
.ab-intro { padding-bottom: 0; }
.ab-intro .ab-statement { position: relative; z-index: 1; margin-bottom: -210px; }
.ab-intro + .sub-section.tint { padding-top: 300px; padding-bottom: 340px; }

/* 베이지 밴드 위에서는 기준 카드를 흰색으로 */
.sub-section.tint .ab-value { background: #fff; }
.sub-section.tint .ab-history li.now .ab-h-card { background: #fdfaf6; border-color: #d9c9b4; }
/* CTA 섹션 */
.ab-cta-sec { padding: 30px 0 100px; }
.ab-cta-sec .pd-cta { margin-top: 0; }
.ab-sec .sec-title { font-size: 34px; font-weight: 300; }
.ab-sec .sec-title::before {
  content: "";
  display: block;
  width: 38px;
  height: 2px;
  margin-bottom: 20px;
  background: #8a6f55;
}
.ab-sec .sec-sub { margin-top: 14px; font-size: 15px; line-height: 1.7; color: #8b837a; word-break: keep-all; }
/* 머무름의 장면들 - 에디토리얼 콜라주 갤러리 */
.ab-gallery { padding: 0 0 20px; margin-top: -210px; }
.ab-gallery-grid {
  display: grid;
  grid-template-columns: repeat(12, 1fr);
  gap: 20px;
}
.ab-g-item {
  position: relative;
  z-index: 1;
  margin: 0;
  border-radius: 18px;
  overflow: hidden;
  cursor: pointer;
}
.ab-g-item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.7s ease;
}
.ab-g-item:hover img { transform: scale(1.07); }
.ab-g-item figcaption {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 40px 20px 16px;
  background: linear-gradient(to top, rgba(20, 16, 12, 0.68), transparent);
  color: #fff;
  font-size: 13px;
  letter-spacing: 0.04em;
  opacity: 0;
  transform: translateY(10px);
  transition: opacity 0.35s ease, transform 0.35s ease;
}
.ab-g-item:hover figcaption { opacity: 1; transform: none; }
/* 심플 배치: 2행 × 4칸 균등 그리드 (사진 6 + 텍스트 2) */
.ab-g-item { grid-column: span 3; height: 270px; }
.ab-g-text {
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 30px 28px;
  background: #2c2723;
  color: #fff;
  cursor: default;
  overflow: hidden;
}
/* 호버: 빛이 스치는 글레어 스윕 */
.ab-g-text::before {
  content: "";
  position: absolute;
  top: 0;
  bottom: 0;
  width: 55%;
  left: -80%;
  transform: skewX(-18deg);
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.13), transparent);
  transition: left 0.7s ease;
  pointer-events: none;
}
.ab-g-text:hover::before { left: 135%; }
.ab-g-text .material-symbols-outlined { font-size: 30px; color: #e7d8c6; }
/* 호버: 제목 아래 라인이 그어짐 */
.ab-g-text h4::after {
  content: "";
  display: block;
  width: 0;
  height: 2px;
  margin-top: 10px;
  background: #e7d8c6;
  transition: width 0.45s ease 0.08s;
}
.ab-g-text:hover h4::after { width: 46px; }
.ab-g-text h4 { margin-top: 18px; font-size: 19px; font-weight: 500; line-height: 1.45; }
.ab-g-text p { margin-top: 11px; font-size: 13.5px; line-height: 1.7; color: rgba(255, 255, 255, 0.65); word-break: keep-all; }
.ab-g-text.tint2 { background: #e7dccd; color: #2c2723; }
.ab-g-text.tint2::before { background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.45), transparent); }
.ab-g-text.tint2 h4::after { background: #8a6f55; }
.ab-g-text.tint2 .material-symbols-outlined { color: #8a6f55; }
.ab-g-text.tint2 p { color: #756d64; }
/* 스크롤 등장 시 순차 스태거 */
.ab-gallery .fx-reveal:nth-child(2) { transition-delay: 0.08s; }
.ab-gallery .fx-reveal:nth-child(3) { transition-delay: 0.16s; }
.ab-gallery .fx-reveal:nth-child(4) { transition-delay: 0.24s; }
.ab-gallery .fx-reveal:nth-child(5) { transition-delay: 0.32s; }
.ab-gallery .fx-reveal:nth-child(6) { transition-delay: 0.4s; }
.ab-gallery .fx-reveal:nth-child(7) { transition-delay: 0.48s; }
.ab-gallery .fx-reveal:nth-child(8) { transition-delay: 0.56s; }
@media (max-width: 880px) {
  .about-page .sub-section > .inner,
  .about-page .ab-gallery > .inner,
  .about-page #footer > .inner {
    padding-left: 24px;
    padding-right: 24px;
  }
  .ab-gallery-grid { grid-template-columns: repeat(2, 1fr); }
  .ab-g-item:nth-child(n) { grid-column: span 1; height: 220px; margin-top: 0; }
  .ab-g-deco { display: none; }
}

.ab-history-sec { padding-top: 150px; }
/* 걸어온 길 - 센터 강조형 헤드 */
.ab-sec-center { text-align: center; margin-bottom: 90px; }
.ab-sec-center .sec-title::before { display: none; }
.ab-sec-center .ab-sec-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 14px;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.32em;
  color: #8a6f55;
}
.ab-sec-center .ab-sec-eyebrow::before,
.ab-sec-center .ab-sec-eyebrow::after {
  content: "";
  width: 0;
  height: 1px;
  background: #d9cdbd;
  transition: width 0.6s ease 0.15s;
}
.ab-sec-center.in .ab-sec-eyebrow::before,
.ab-sec-center.in .ab-sec-eyebrow::after { width: 42px; }
.ab-sec-center .sec-title {
  margin-top: 20px;
  font-size: 60px;
  font-weight: 200;
  letter-spacing: -0.02em;
  line-height: 1.15;
}
.ab-sec-center .sec-title em {
  font-style: normal;
  font-weight: 600;
  color: #8a6f55;
}
/* 고스트 타이포: 연도 레인지가 타이틀 뒤에 깔림 */
.ab-sec-center .ab-sec-ghostwrap { position: relative; padding-top: 44px; }
.ab-sec-center .ab-sec-ghost {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  z-index: 0;
  font-family: 'Wave', sans-serif;
  font-size: 110px;
  line-height: 1;
  letter-spacing: 0.04em;
  white-space: nowrap;
  color: #f1e9e0;
  user-select: none;
  pointer-events: none;
  opacity: 0;
  letter-spacing: -0.08em;
  transition: opacity 1.1s ease, letter-spacing 1.3s cubic-bezier(0.22, 1, 0.36, 1);
}
.ab-sec-center.in .ab-sec-ghost { opacity: 1; letter-spacing: 0.04em; }
.ab-sec-center .sec-title {
  position: relative;
  z-index: 1;
  margin-top: 0;
  opacity: 0;
  transform: translateY(26px);
  transition: opacity 0.7s ease 0.25s, transform 0.7s ease 0.25s;
}
.ab-sec-center.in .sec-title { opacity: 1; transform: none; }
.ab-sec-center .sec-sub {
  opacity: 0;
  transform: translateY(14px);
  transition: opacity 0.6s ease 0.5s, transform 0.6s ease 0.5s;
}
.ab-sec-center.in .sec-sub { opacity: 1; transform: none; }
@media (max-width: 680px) {
  .ab-sec-center .ab-sec-ghost { font-size: 58px; }
  .ab-sec-center .ab-sec-ghostwrap { padding-top: 24px; }
}
.ab-sec-center .sec-sub { margin-top: 22px; font-size: 16.5px; font-weight: 200; color: #756d64; }
@media (max-width: 680px) {
  .ab-sec-center .sec-title { font-size: 38px; }
}
.ab-values { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
.ab-value {
  position: relative;
  padding: 38px 32px;
  background: #f7f3ef;
  border-radius: 18px;
  transition: transform 0.3s, box-shadow 0.3s;
}
.ab-value:hover { transform: translateY(-5px); box-shadow: 0 18px 40px rgba(120, 100, 85, 0.14); }
/* 호버 시 갈색 라인(둘레의 약 30%)이 테두리를 따라 회전 */
@property --ab-angle {
  syntax: '<angle>';
  initial-value: 0deg;
  inherits: false;
}
.ab-value::before {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 18px;
  padding: 1px;
  background: conic-gradient(
    from var(--ab-angle),
    transparent 0deg,
    transparent 250deg,
    #8a6f55 268deg,
    #8a6f55 342deg,
    transparent 360deg
  );
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  mask-composite: exclude;
  opacity: 0;
  transition: opacity 0.3s;
  pointer-events: none;
}
.ab-value:hover::before {
  opacity: 1;
  animation: ab-line-spin 2.4s linear infinite;
}
@keyframes ab-line-spin {
  to { --ab-angle: 360deg; }
}
.ab-value .num { position: absolute; top: 36px; right: 32px; font-family: 'Wave', sans-serif; font-size: 15px; font-weight: normal; letter-spacing: 0.1em; color: #c9b9a4; }
.ab-value .ab-ic {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 48px;
  height: 48px;
  border-radius: 14px;
  background: #f1e9e0;
  color: #8a6f55;
  font-size: 24px;
}
.ab-value h3 { margin-top: 20px; font-size: 21px; font-weight: 400; color: #2c2723; }
.ab-value p { margin-top: 12px; font-size: 14.5px; font-weight: 200; line-height: 1.8; color: #756d64; word-break: keep-all; }

.ab-history {
  list-style: none;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
}
.ab-history li {
  position: relative;
  display: flex;
  flex-direction: column;
}
/* 가로 라인 */
.ab-history li::before {
  content: "";
  position: absolute;
  top: 100px;
  left: 0;
  right: -24px;
  height: 1px;
  background: linear-gradient(to right, #d9cdbd, #ece7e1);
}
.ab-history li:last-child::before { right: 0; }
/* 도트 */
.ab-history li::after {
  content: "";
  position: absolute;
  left: 2px;
  top: 100px;
  transform: translateY(calc(-50% + 0.5px));
  width: 11px;
  height: 11px;
  border-radius: 50%;
  background: #fff;
  border: 2px solid #b9a488;
  transition: background 0.25s, border-color 0.25s, box-shadow 0.25s;
}
.ab-history li:hover::after,
.ab-history li.lit::after,
.ab-history li.now::after {
  background: #8a6f55;
  border-color: #8a6f55;
  box-shadow: 0 0 0 5px rgba(138, 111, 85, 0.15);
}
/* 연도 */
.ab-history .year {
  font-family: 'Wave', sans-serif;
  font-size: 42px;
  font-weight: normal;
  color: #2c2723;
  letter-spacing: 0.01em;
  line-height: 1;
}
.ab-history .y-txt { display: inline-block; min-width: 4ch; min-height: 1em; }
.ab-history .year.typing .y-txt::after {
  content: "";
  display: inline-block;
  width: 3px;
  height: 0.8em;
  margin-left: 4px;
  background: #8a6f55;
  vertical-align: -2px;
  animation: caret-blink 0.7s steps(1) infinite;
}
@keyframes caret-blink { 50% { opacity: 0; } }
.ab-history .year em {
  display: block;
  margin-top: 7px;
  font-family: 'A2z', sans-serif;
  font-style: normal;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.18em;
  color: #b3a290;
}
/* 콘텐츠 카드 */
.ab-history .ab-h-card {
  position: relative;
  flex: 1;
  margin-top: 80px;
  padding: 24px 26px 26px;
  background: #fff;
  border: 1px solid #ece7e1;
  border-radius: 16px;
  transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
}
.ab-history li:hover .ab-h-card {
  transform: translateY(-5px);
  border-color: #d9cdbd;
  box-shadow: 0 16px 34px rgba(120, 100, 85, 0.12);
}
.ab-history li.now .ab-h-card { background: #f7f3ef; border-color: #e2d6c5; }
.ab-history .ab-h-now {
  position: absolute;
  top: 24px;
  right: 22px;
  padding: 4px 11px;
  border-radius: 50px;
  background: #8a6f55;
  color: #fff;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.14em;
}
.ab-history h4 { font-size: 16.5px; font-weight: 400; color: #2c2723; padding-right: 44px; }
.ab-history li:not(.now) h4 { padding-right: 0; }
.ab-history p { margin-top: 10px; font-size: 14px; font-weight: 200; line-height: 1.75; color: #8b837a; word-break: keep-all; }
.ab-history + .pd-cta { margin-top: 90px; }

@media (max-width: 1100px) {
  .ab-history { grid-template-columns: repeat(2, 1fr); row-gap: 44px; }
  .ab-history li:nth-child(2n)::before { right: 0; }
}
@media (max-width: 680px) {
  .ab-history { grid-template-columns: 1fr; row-gap: 28px; }
  .ab-history li::before, .ab-history li::after { display: none; }
  .ab-history .year { display: flex; align-items: baseline; gap: 8px; }
  .ab-history .year em { margin-top: 0; }
  .ab-history .ab-h-card { margin-top: 12px; }
}

@media (max-width: 880px) {
  .ab-values { grid-template-columns: 1fr; }
  .ab-statement { height: 340px; }
  .ab-statement .quote { font-size: 18px; }
}

/* ================================================================
   프로모션 카드 — 날짜 강조 리디자인 (pc-date-block)
   ================================================================ */

/* 기존 .foot 을 블록으로 전환 */
.promo-card .foot {
  display: block;
  margin-top: 28px;
  padding-top: 0;
  border-top: none;
}

/* 날짜 블록 컨테이너 */
.pc-date-block {
  padding: 18px 20px 16px;
  background: #faf7f4;
  border-radius: 14px;
  border: 1px solid #ede6de;
}

/* 상단: FROM ── 진행바 ── UNTIL */
.pc-date-top {
  display: flex;
  align-items: center;
  gap: 14px;
}
.pc-date-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 54px;
}

/* 라벨 (FROM / UNTIL) */
.dc-label {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.2em;
  color: #b3a290;
  text-transform: uppercase;
}

/* 큰 날짜 숫자 */
.dc-day {
  font-size: 46px;
  font-weight: 700;
  line-height: 1;
  color: #2c2723;
  letter-spacing: -0.03em;
  margin: 5px 0 4px;
}

/* 월 + 연도 */
.dc-mon {
  font-size: 10px;
  color: #9a8e86;
  letter-spacing: 0.08em;
  font-weight: 500;
  text-transform: uppercase;
  white-space: nowrap;
}

/* 중간 진행바 영역 */
.pc-date-track {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.pc-track-bar {
  width: 100%;
  height: 3px;
  background: #ede6de;
  border-radius: 2px;
  overflow: hidden;
}
.pc-track-fill {
  height: 100%;
  background: linear-gradient(90deg, #8a6f55, #c4a478);
  border-radius: 2px;
  width: 0;
  transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
}
.dc-event-tag {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.2em;
  color: #c9bdb2;
  text-transform: uppercase;
}

/* 하단: 잔여일 + CTA */
.pc-date-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 14px;
  padding-top: 12px;
  border-top: 1px solid #ede6de;
}
.pc-remain {
  display: inline-flex;
  align-items: baseline;
  gap: 4px;
}
.remain-num {
  font-size: 26px;
  font-weight: 700;
  color: #c1654b;
  line-height: 1;
  letter-spacing: -0.02em;
}
.remain-txt {
  font-size: 12px;
  color: #c1654b;
  font-weight: 500;
  letter-spacing: 0.02em;
}

/* 상시 진행 변형 */
.pc-date-block--always .pc-date-top { align-items: flex-end; }
.dc-day--always {
  font-size: 38px;
  letter-spacing: 0;
  color: #8a6f55;
}
.pc-remain--always .remain-num { font-size: 14px; color: #8a6f55; letter-spacing: 0; }
.pc-remain--always .remain-txt { font-size: 13px; color: #8a6f55; }

/* 종료된 카드 */
.promo-card.ended .pc-date-block {
  background: #f5f3f0;
  border-color: #e5e0db;
}
.promo-card.ended .dc-day { color: #c2bcb6; }
.promo-card.ended .dc-mon,
.promo-card.ended .dc-label { color: #ccc6c0; }
.promo-card.ended .pc-track-fill {
  background: #d0cac4;
  width: 100% !important;
}
.promo-card.ended .remain-num { font-size: 13px; font-weight: 600; color: #b0a89e; }
.promo-card.ended .remain-txt { font-size: 12px; color: #b0a89e; }


/* ================================================================
   프로모션 카드 — 2열 그리드 레이아웃
   ================================================================ */
.promo-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 28px;
  align-items: start;
}

/* 세로 카드로 전환 */
.promo-card {
  grid-template-columns: 1fr;
  gap: 0;
  align-items: stretch;
}

.promo-card .thumb {
  height: 220px;
}

.promo-card .body {
  padding: 26px 28px 24px;
}

.promo-card h3 {
  font-size: 20px;
}

.promo-card p {
  font-size: 14px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 날짜 블록 축소 */
.promo-card .dc-day {
  font-size: 34px;
}

.promo-card .pc-date-block {
  padding: 14px 16px 12px;
}

.promo-card .remain-num {
  font-size: 20px;
}

/* 모바일: 1열 */
@media (max-width: 720px) {
  .promo-list {
    grid-template-columns: 1fr;
  }
}

/* ================================================================
   프로모션 — 콜라주(컬러 타일) 그리드  [참고 레퍼런스 적용]
   ================================================================ */
.promo-collage {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  align-items: start;
}
.promo-collage .promo-card {
  display: flex;
  flex-direction: column;
  grid-template-columns: none;
  gap: 0;
  border: none;
  border-radius: 20px;
  overflow: hidden;
  background: #c1654b;
  box-shadow: none;
  transition: transform 0.35s ease, box-shadow 0.35s ease;
}
.promo-collage .promo-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 24px 48px rgba(120, 100, 85, 0.18);
}
/* 사진 영역 */
.promo-collage .promo-card .thumb {
  position: relative;
  height: 200px;
  overflow: hidden;
}
.promo-collage .promo-card .thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.7s ease;
}
.promo-collage .promo-card:hover .thumb img { transform: scale(1.06); }
/* 컬러 본문 */
.promo-collage .promo-card .body {
  display: flex;
  flex-direction: column;
  flex: 1;
  padding: 26px 26px 24px;
}
.promo-collage .promo-card h3 {
  margin: 0;
  font-size: 21px;
  font-weight: 600;
  line-height: 1.34;
  letter-spacing: -0.01em;
}
.promo-collage .promo-card p {
  margin: 12px 0 0;
  font-size: 13.5px;
  line-height: 1.7;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
/* 이미지 위 칩 */
.pc-chip {
  position: absolute;
  top: 14px;
  left: 14px;
  padding: 6px 13px;
  border-radius: 50px;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(6px);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  color: #8a6f55;
}
.pc-gift {
  position: absolute;
  top: 14px;
  right: 14px;
  display: in